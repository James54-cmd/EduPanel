@inherits LayoutComponentBase
@implements IDisposable
@inject IBrowserViewportService BrowserViewportService
@inject NavigationManager NavigationManager

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="true">
        @if (_isMobileOrTablet)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" Size="Size.Small" />
        }
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Size="Size.Small" />
        <MudAvatar Size="Size.Small" Class="ml-4 avatar-gradient-secondary">AD</MudAvatar>
    </MudAppBar>

    @if (_isMobileOrTablet)
    {
        @if (_drawerOpen)
        {
            <div class="mobile-nav-overlay" @onclick="CloseDrawer"></div>
            <div class="mobile-nav-panel">
                <div class="d-flex align-center pa-3 border-b flex-shrink-0">
                    <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" Size="Size.Small" Class="mr-2"/>
                    <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="font-weight-bold">EduPanel</MudText>
                </div>
                <div class="flex-grow-1" style="overflow-y: auto;">
                    <NavMenu />
                </div>
            </div>
        }

        <MudMainContent Class="mud-main-content-custom">
            <div class="pa-4">
                @Body
            </div>
        </MudMainContent>
    }
    else
    {
        <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Docked" Variant="@DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
            <div class="d-flex align-center pa-4 flex-shrink-0 border-b mud-border-lines-default" style="height: 48px;">
                <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" Size="Size.Medium" Class="mr-2"/>
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold text-truncate">EduPanel</MudText>
            </div>
            <div class="flex-grow-1" style="overflow-y: auto;">
                <NavMenu />
            </div>
        </MudDrawer>

        <MudMainContent Class="mud-main-content-custom">
            <div class="pa-6">
                @Body
            </div>
        </MudMainContent>
    }

    <MudScrollToTop Style="left: 50%; right: auto; transform: translateX(-50%); bottom: 24px;" Class="scroll-to-top-btn">
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
    </MudScrollToTop>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool _drawerOpen = true;
    bool _isMobileOrTablet = false;
    Guid _observerId = Guid.Empty;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var observer = new ViewportObserver(OnBreakpointChanged);
            _observerId = observer.Id;

            await BrowserViewportService.SubscribeAsync(observer, fireImmediately: true);
        }
    }

    private async Task OnBreakpointChanged(Breakpoint breakpoint)
    {
        var wasMobile = _isMobileOrTablet;

        _isMobileOrTablet = breakpoint <= Breakpoint.Md;

        if (_isMobileOrTablet && !wasMobile)
            _drawerOpen = false;
        else if (!_isMobileOrTablet && wasMobile)
            _drawerOpen = true;

        await InvokeAsync(StateHasChanged);
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_isMobileOrTablet && _drawerOpen)
        {
            _drawerOpen = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    void CloseDrawer()  => _drawerOpen = false;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        _ = BrowserViewportService.UnsubscribeAsync(_observerId);
    }

    private sealed class ViewportObserver : IBrowserViewportObserver
    {
        private readonly Func<Breakpoint, Task> _callback;

        public ViewportObserver(Func<Breakpoint, Task> callback)
            => _callback = callback;

        public Guid Id { get; } = Guid.NewGuid();

        public MudBlazor.Services.ResizeOptions ResizeOptions { get; } = new()
        {
            ReportRate = 200,             // debounce ms — avoids firing on every px
            NotifyOnBreakpointOnly = true // only fires when crossing Xs/Sm/Md/Lg/Xl
        };

        public Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs args)
            => _callback(args.Breakpoint);
    }
}
