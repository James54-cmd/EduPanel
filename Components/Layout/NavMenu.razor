@implements IDisposable
@inject NavigationManager NavManager

<MudNavMenu Margin="Margin.Dense" Bordered="true">
    @if (IsEmployeeView)
    {
        <MudNavGroup Title="My Profile" Icon="@Icons.Material.Filled.Person" ExpandIcon="@Icons.Material.Filled.ArrowDropDown" Expanded="@(_expandedGroup == "Profile")" ExpandedChanged="@((e) => _expandedGroup = e ? "Profile" : "")" HideExpandIcon="false" Class="@ProfileGroupClass">
            <MudNavLink Href="/employee/profile" Match="NavLinkMatch.All">Employee Profile</MudNavLink>
            <MudNavLink Href="/employee/personal-data-update" Match="NavLinkMatch.All">Personal Data Update</MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Attendance" Icon="@Icons.Material.Filled.AccessTime" ExpandIcon="@Icons.Material.Filled.ArrowDropDown" Expanded="@(_expandedGroup == "Attendance")" ExpandedChanged="@((e) => _expandedGroup = e ? "Attendance" : "")" HideExpandIcon="false" Class="@AttendanceGroupClass">
            <MudNavLink Href="/employee/attendance/inquiry" Match="NavLinkMatch.All">Attendance Inquiry</MudNavLink>
            <MudNavLink Href="/employee/attendance/schedule-calendar" Match="NavLinkMatch.All">My Schedule Calendar</MudNavLink>
            <MudNavLink Href="/employee/attendance/change-shift" Match="NavLinkMatch.All">Change Shift</MudNavLink>
            <MudNavLink Href="/employee/attendance/change-day-off" Match="NavLinkMatch.All">Change Day Off</MudNavLink>
            <MudNavLink Href="/employee/attendance/time-declaration" Match="NavLinkMatch.All">Time Declaration</MudNavLink>
            <MudNavLink Href="/employee/attendance/leave-ob" Match="NavLinkMatch.All">Leave / OB</MudNavLink>
            <MudNavLink Href="/employee/attendance/leave-cancellation" Match="NavLinkMatch.All">Leave Cancellation</MudNavLink>
            <MudNavLink Href="/employee/attendance/leave-balance" Match="NavLinkMatch.All">Leave Balance</MudNavLink>
            <MudNavLink Href="/employee/attendance/overtime-application" Match="NavLinkMatch.All">Overtime Application</MudNavLink>
            <MudNavLink Href="/employee/attendance/dtr" Match="NavLinkMatch.All">DTR</MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Payroll" Icon="@Icons.Material.Filled.AttachMoney" ExpandIcon="@Icons.Material.Filled.ArrowDropDown" Expanded="@(_expandedGroup == "Payroll")" ExpandedChanged="@((e) => _expandedGroup = e ? "Payroll" : "")" HideExpandIcon="false" Class="@PayrollGroupClass">
            <MudNavLink Href="/employee/payroll/payroll-inquiry" Match="NavLinkMatch.All">Payroll Inquiry</MudNavLink>
            <MudNavLink Href="/employee/payroll/loan-inquiry" Match="NavLinkMatch.All">Loan Inquiry</MudNavLink>
            <MudNavLink Href="/employee/payroll/contribution-inquiry" Match="NavLinkMatch.All">Contribution Inquiry</MudNavLink>
        </MudNavGroup>
        
        <MudNavGroup Title="Human Resource" Icon="@Icons.Material.Filled.People" ExpandIcon="@Icons.Material.Filled.ArrowDropDown" Expanded="@(_expandedGroup == "HumanResource")" ExpandedChanged="@((e) => _expandedGroup = e ? "HumanResource" : "")" HideExpandIcon="false" Class="@HumanResourceGroupClass">
            <MudNavLink Href="/employee/human-resource/benefit-balance" Match="NavLinkMatch.All">Benefit Balance</MudNavLink>
            <MudNavLink Href="/employee/human-resource/benefit-enrollment" Match="NavLinkMatch.All">Benefit Enrollment</MudNavLink>
            <MudNavLink Href="/employee/human-resource/benefit-application" Match="NavLinkMatch.All">Benefit Application</MudNavLink>
            <MudNavLink Href="/employee/human-resource/employee-request" Match="NavLinkMatch.All">Employee Request</MudNavLink>
            <MudNavLink Href="/employee/human-resource/er-activities" Match="NavLinkMatch.All">ER Activities</MudNavLink>
            <MudNavLink Href="/employee/human-resource/saln-form" Match="NavLinkMatch.All">SALN Form</MudNavLink>
            <MudNavLink Href="/employee/human-resource/clearance" Match="NavLinkMatch.All">Clearance</MudNavLink>
            <MudNavLink Href="/employee/human-resource/employee-evaluation" Match="NavLinkMatch.All">Employee Evaluation</MudNavLink>
            <MudNavLink Href="/employee/human-resource/career-opportunities" Match="NavLinkMatch.All">Career Opportunities</MudNavLink>
            <MudNavLink Href="/employee/human-resource/incident-reporting" Match="NavLinkMatch.All">Incident Reporting</MudNavLink>
            <MudNavLink Href="/employee/human-resource/notice-to-explain" Match="NavLinkMatch.All">Notice to Explain</MudNavLink>
            <MudNavLink Href="/employee/human-resource/my-applications" Match="NavLinkMatch.All">My Application/s</MudNavLink>
        </MudNavGroup>
    }
    else
    {
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
        <MudNavLink Href="/admin/employee" Icon="@Icons.Material.Filled.People">Employees</MudNavLink>
        <MudNavLink Href="#" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Store">Store</MudNavLink>
        <MudNavLink Href="#" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">Library</MudNavLink>
        <MudNavLink Href="#" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Group">Community</MudNavLink>
    }
</MudNavMenu>

@code {
    // Single state variable for the currently expanded group
    private string _expandedGroup = "";

    private bool IsEmployeeView => NavManager.Uri.Contains("/employee", StringComparison.OrdinalIgnoreCase);

    private bool IsProfileActive => NavManager.Uri.Contains("/employee/profile", StringComparison.OrdinalIgnoreCase)
        || NavManager.Uri.Contains("/employee/personal-data-update", StringComparison.OrdinalIgnoreCase);

    private bool IsAttendanceActive => NavManager.Uri.Contains("/employee/attendance", StringComparison.OrdinalIgnoreCase);

    private bool IsHumanResourceActive => NavManager.Uri.Contains("/employee/human-resource", StringComparison.OrdinalIgnoreCase);

    private bool IsPayrollActive => NavManager.Uri.Contains("/employee/payroll", StringComparison.OrdinalIgnoreCase);

    private string ProfileGroupClass => IsProfileActive ? "nav-group-active" : "";
    private string AttendanceGroupClass => IsAttendanceActive ? "nav-group-active" : "";
    private string HumanResourceGroupClass => IsHumanResourceActive ? "nav-group-active" : "";
    private string PayrollGroupClass => IsPayrollActive ? "nav-group-active" : "";

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
        SyncExpandedState();
    }
    
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SyncExpandedState();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Auto-expand the group whose section is active.
    /// </summary>
    private void SyncExpandedState()
    {
        if (IsProfileActive) _expandedGroup = "Profile";
        else if (IsAttendanceActive) _expandedGroup = "Attendance";
        else if (IsHumanResourceActive) _expandedGroup = "HumanResource";
        else if (IsPayrollActive) _expandedGroup = "Payroll";
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
