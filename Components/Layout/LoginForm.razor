@using FluentValidation
@inject NavigationManager Nav

<div class="d-flex flex-column gap-6 w-100">
    <div class="d-flex flex-column align-center gap-2 text-center mb-4">
        <MudText Typo="Typo.h5" Class="font-weight-bold">Login to your account</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Enter your email below to login to your account
        </MudText>
    </div>

    <MudForm @ref="form" Model="@model" Validation="@(modelValidator.ValidateValue)" Class="d-flex flex-column gap-4">
        
        <!-- Email Field -->
        <div class="d-flex flex-column gap-1">
            <MudText Typo="Typo.body2" Class="font-weight-medium text-left">Email</MudText>
            <MudTextField @bind-Value="model.Email"
                          For="@(() => model.Email)"
                          Placeholder="m@example.com"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true" />
        </div>

        <!-- Password Field -->
        <div class="d-flex flex-column gap-1 mt-2">
            <div class="d-flex align-center justify-space-between w-100">
                <MudText Typo="Typo.body2" Class="font-weight-medium">Password</MudText>
                <MudLink Href="#" Typo="Typo.body2" Underline="Underline.Hover" Color="Color.Secondary" Style="font-size: 0.85rem;">
                    Forgot your password?
                </MudLink>
            </div>
            <MudTextField @bind-Value="model.Password"
                          For="@(() => model.Password)"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-1">
                @errorMessage
            </MudText>
        }

        <!-- Submit Button -->
        <MudButton OnClick="SubmitLogin"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   FullWidth="true"
                   Class="py-2.5 mt-2 font-weight-bold"
                   Style="text-transform: none;">
            Login
        </MudButton>

        <!-- Separator -->
        <div class="d-flex align-center my-4">
            <hr class="flex-grow-1" style="border: 0; border-top: 1px solid var(--mud-palette-divider); opacity: 0.5;" />
            <MudText Typo="Typo.body2" Class="px-3 mud-text-secondary" Style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">
                Or continue with
                </MudText>
            <hr class="flex-grow-1" style="border: 0; border-top: 1px solid var(--mud-palette-divider); opacity: 0.5;" />
        </div>

        <!-- GitHub Button -->
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   FullWidth="true"
                   Class="py-2.5 d-flex align-center justify-center gap-2"
                   Style="text-transform: none; border-color: var(--mud-palette-divider);">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width: 16px; height: 16px; fill: currentColor;">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            <span>Login with GitHub</span>
        </MudButton>

        <div class="text-center mt-3">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Don't have an account? 
                <MudLink Href="#" Underline="Underline.Hover" Color="Color.Primary" Class="font-weight-medium">
                    Sign up
                </MudLink>
            </MudText>
        </div>

    </MudForm>
</div>

@code {
    private MudForm form = null!;
    private LoginModel model = new();
    private LoginModelValidator modelValidator = new();
    private string errorMessage = "";

    private async Task SubmitLogin()
    {
        await form.ValidateAsync();

        if (form.IsValid)
        {
            if (model.Email == "admin@example.com" && model.Password == "admin123")
            {
                Nav.NavigateTo("/dashboard");
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    public class LoginModelValidator : AbstractValidator<LoginModel>
    {
        public LoginModelValidator()
        {
            RuleFor(x => x.Email)
                .NotEmpty().WithMessage("Email is required.")
                .EmailAddress().WithMessage("A valid email address is required.");

            RuleFor(x => x.Password)
                .NotEmpty().WithMessage("Password is required.")
                .MinimumLength(6).WithMessage("Password must be at least 6 characters.");
        }

        public Func<object, string, Task<IEnumerable<string>>> ValidateValue => async (model, propertyName) =>
        {
            var result = await ValidateAsync(ValidationContext<LoginModel>.CreateWithOptions((LoginModel)model, x => x.IncludeProperties(propertyName)));
            if (result.IsValid)
                return Array.Empty<string>();
            return result.Errors.Select(e => e.ErrorMessage);
        };
    }
}
