@using FluentValidation
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudForm @ref="form" Model="@model" Validation="@(modelValidator.ValidateValue)" ValidationDelay="0" Class="w-100">
    <FieldGroup>
        <div class="d-flex flex-column align-center gap-1 text-center mb-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold">Login to your account</MudText>
            <FieldDescription>
                Enter your email below to login to your account
            </FieldDescription>
        </div>

        <Field>
            <FieldLabel HtmlFor="email">Email</FieldLabel>
            <MudTextField @bind-Value="model.Email"
                          For="@(() => model.Email)"
                          Validation="@(modelValidator.ValidateValue)"
                          Immediate="true"
                          Placeholder="m@example.com"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true" />
        </Field>

        <Field>
            <div class="d-flex align-center justify-space-between w-100">
                <FieldLabel HtmlFor="password">Password</FieldLabel>
                <MudLink Href="#" Typo="Typo.body2" Underline="Underline.Hover" Color="Color.Secondary" Style="font-size: 0.85rem;">
                    Forgot your password?
                </MudLink>
            </div>
            <MudTextField @bind-Value="model.Password"
                          For="@(() => model.Password)"
                          Validation="@(modelValidator.ValidateValue)"
                          Immediate="true"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true" />
        </Field>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudText Color="Color.Error" Typo="Typo.body2" Class="mt-1">
                @errorMessage
            </MudText>
        }

        <Field>
            <LoadingButton OnClick="SubmitLogin"
                           IsLoading="@_loading"
                           LoadingText="Logging in..."
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Class="font-weight-bold">
                <span>Login</span>
            </LoadingButton>
        </Field>

        <FieldSeparator>Or continue with</FieldSeparator>

        <Field>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       FullWidth="true"
                       Class="py-2.5"
                       Style="text-transform: none; border-color: var(--mud-palette-divider);">
                <div class="d-flex align-center justify-center gap-2">
                    <Blazicon Svg="BootstrapIcon.Github" style="width: 16px; height: 16px; fill: currentColor;" />
                    <span>Login with GitHub</span>
                </div>
            </MudButton>
            
            <FieldDescription Class="text-center mt-3">
                Don't have an account? 
                <MudLink Href="#" Underline="Underline.Hover" Color="Color.Primary" Class="font-weight-medium">
                    Sign up
                </MudLink>
            </FieldDescription>
        </Field>
    </FieldGroup>
</MudForm>

@code {
    private MudForm form = null!;
    private LoginModel model = new();
    private LoginModelValidator modelValidator = new();
    private string errorMessage = "";
    private bool _loading = false;

    private async Task SubmitLogin()
    {
        Console.WriteLine($"[Login] Starting login for: {model.Email}");
        await form.ValidateAsync();
        errorMessage = "";

        Console.WriteLine($"[Login] Form IsValid after validation: {form.IsValid}");
        if (form.IsValid)
        {
            _loading = true;
            StateHasChanged();

            Console.WriteLine("[Login] Simulating network delay...");
            // Simulate network delay for UX
            await Task.Delay(1500);

            if (model.Email == "admin@example.com" && model.Password == "admin123")
            {
                Console.WriteLine("[Login] Credentials matched. Navigating to dashboard...");
                Snackbar.Add("Login successful!", MudBlazor.Severity.Success);
                Nav.NavigateTo("/dashboard");
            }
            else if (model.Email == "employee@example.com" && model.Password == "employee123")
            {
                Console.WriteLine("[Login] Credentials matched. Navigating to employee dashboard...");
                Snackbar.Add("Login successful as Employee!", MudBlazor.Severity.Success);
                Nav.NavigateTo("/employee/dashboard");
            }
            else
            {
                Console.WriteLine("[Login] Credentials failed. Showing error...");
                errorMessage = "Invalid email or password.";
                Snackbar.Add("Login failed. Please check your credentials.", MudBlazor.Severity.Error);
            }

            _loading = false;
        }
        else
        {
            Console.WriteLine("[Login] Form is invalid. Stopping submission.");
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    public class LoginModelValidator : AbstractValidator<LoginModel>
    {
        public LoginModelValidator()
        {
            RuleFor(x => x.Email)
                .Cascade(CascadeMode.Stop)
                .NotEmpty().WithMessage("Email is required.")
                .EmailAddress().WithMessage("A valid email address is required.");

            RuleFor(x => x.Password)
                .NotEmpty().WithMessage("Password is required.")
                .MinimumLength(6).WithMessage("Password must be at least 6 characters.");
        }

        public Func<object, string, Task<IEnumerable<string>>> ValidateValue => async (model, propertyName) =>
        {
            var result = await ValidateAsync(ValidationContext<LoginModel>.CreateWithOptions((LoginModel)model, x => x.IncludeProperties(propertyName)));
            if (result.IsValid)
                return Array.Empty<string>();
            return result.Errors.Select(e => e.ErrorMessage);
        };
    }
}
