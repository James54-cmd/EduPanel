@page "/admin/employee"
@namespace EduPanel.Components.Pages.Admin

<div class="mb-6">
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h5" Class="font-weight-bold">Employees</MudText>
    </div>
    <div class="d-flex justify-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
            Add Employee
        </MudButton>
    </div>
</div>

<DataTable TItem="EmployeeModel"
           Items="@Employees"
           Columns="@Columns"
           PageSize="20"
           BodyHeight="calc(100vh - 20rem)"
           EmptyText="No employees found"
           OnRowClick="@HandleRowClick">
    <MobileCardTemplate Context="emp">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:6px;">
            <div style="display:flex; align-items:center; gap:10px; min-width:0;">
                <MudAvatar Size="Size.Small" Class="avatar-gradient-primary">@emp.Name.Substring(0,1)</MudAvatar>
                <div style="min-width:0;">
                    <div style="font-size:.9rem;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@emp.Name</div>
                    <div style="font-size:.75rem;color:#6b7280;">@emp.Role · @emp.Department</div>
                </div>
            </div>
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                     Dense="true">
                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary">Edit</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
            </MudMenu>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:.75rem;color:#9ca3af;">ID: @emp.Id</span>
            <MudChip T="string" Size="Size.Small" Color="@(emp.IsActive ? Color.Success : Color.Error)">
                @(emp.IsActive ? "Active" : "Inactive")
            </MudChip>
        </div>
    </MobileCardTemplate>

</DataTable>

@code {
    private bool UseEllipsisActions = true;

    public class EmployeeModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string Department { get; set; } = "";
        public bool IsActive { get; set; }
    }

    private List<EmployeeModel> Employees = new()
    {
        new EmployeeModel { Id = 1001, Name = "Alice Smith",   Role = "Senior Teacher", Department = "Science",        IsActive = true  },
        new EmployeeModel { Id = 1002, Name = "Bob Jones",     Role = "Teacher",        Department = "Math",           IsActive = true  },
        new EmployeeModel { Id = 1003, Name = "Charlie Brown", Role = "Admin",          Department = "Administration", IsActive = false },
        new EmployeeModel { Id = 1004, Name = "Diana Prince",  Role = "Counselor",      Department = "Support",        IsActive = true  },
        new EmployeeModel { Id = 1005, Name = "Evan Wright",   Role = "Teacher",        Department = "History",        IsActive = true  },
        new EmployeeModel { Id = 1006, Name = "Fiona Green",   Role = "Teacher",        Department = "English",        IsActive = true  },
        new EmployeeModel { Id = 1007, Name = "George Hall",   Role = "Teacher",        Department = "PE",             IsActive = false },
    };

    private List<DataTable<EmployeeModel>.ColumnDef<EmployeeModel>> Columns => new()
    {
        new()
        {
            Header     = "ID",
            GridWidth  = "minmax(60px, 0.6fr)",
            CellTemplate = emp => @<span style="font-weight:600;color:#374151;">@emp.Id</span>
        },
        new()
        {
            Header     = "Name",
            GridWidth  = "minmax(140px, 2fr)",
            CellTemplate = emp => @<div style="display:flex;align-items:center;gap:10px;">
                <MudAvatar Size="Size.Small" Class="avatar-gradient-primary">@emp.Name.Substring(0,1)</MudAvatar>
                <span style="font-weight:600;">@emp.Name</span>
            </div>
        },
        new()
        {
            Header     = "Role",
            GridWidth  = "minmax(120px, 1.5fr)",
            CellTemplate = emp => @<span>@emp.Role</span>
        },
        new()
        {
            Header     = "Department",
            GridWidth  = "minmax(120px, 1.5fr)",
            CellTemplate = emp => @<span>@emp.Department</span>
        },
        new()
        {
            Header     = "Status",
            GridWidth  = "minmax(90px, 0.9fr)",
            CellTemplate = emp => @<MudChip T="string" Size="Size.Small"
                                             Color="@(emp.IsActive ? Color.Success : Color.Error)">
                @(emp.IsActive ? "Active" : "Inactive")
            </MudChip>
        },
        new()
        {
            Header     = UseEllipsisActions ? "" : "Actions",
            GridWidth  = "minmax(80px, 0.8fr)",
            HideOnMobile = true,
            CellTemplate = emp => @<text>
                @if (UseEllipsisActions)
                {
                    <div style="display:flex; justify-content: flex-end;">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary">Edit</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
                        </MudMenu>
                    </div>
                }
                else
                {
                    <div style="display:flex;gap:4px;">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"  Color="Color.Primary" Size="Size.Small" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"   Size="Size.Small" />
                    </div>
                }
            </text>
        },
    };

    private void HandleRowClick(EmployeeModel emp)
    {
        // TODO: open detail drawer / dialog
    }
}
