    private List<DataTable<EmployeeModel>.ColumnDef<EmployeeModel>> Columns => new()
    {
        new()
        {
            Header     = "ID",
            GridWidth  = "minmax(60px, 0.6fr)",
            CellTemplate = emp => @<span style="font-weight:600;color:#374151;">@emp.Id</span>
        },
        new()
        {
            Header     = "Name",
            GridWidth  = "minmax(140px, 2fr)",
            CellTemplate = emp => @<div style="display:flex;align-items:center;gap:10px;">
                <MudAvatar Size="Size.Small" Class="avatar-gradient-primary">@emp.Name.Substring(0,1)</MudAvatar>
                <span style="font-weight:600;">@emp.Name</span>
            </div>
        },
        new()
        {
            Header     = "Role",
            GridWidth  = "minmax(120px, 1.5fr)",
            CellTemplate = emp => @<span>@emp.Role</span>
        },
        new()
        {
            Header     = "Department",
            GridWidth  = "minmax(120px, 1.5fr)",
            CellTemplate = emp => @<span>@emp.Department</span>
        },
        new()
        {
            Header     = "Email",
            GridWidth  = "minmax(140px, 1.5fr)",
            HideOnMobile = true,
            CellTemplate = emp => @<span style="color:#6b7280; font-size: 0.8rem;">@emp.Email</span>
        },
        new()
        {
            Header     = "Phone",
            GridWidth  = "minmax(110px, 1fr)",
            HideOnMobile = true,
            CellTemplate = emp => @<span style="color:#6b7280; font-size: 0.8rem;">@emp.Phone</span>
        },
        new()
        {
            Header     = "Hire Date",
            GridWidth  = "minmax(100px, 1fr)",
            HideOnMobile = true,
            CellTemplate = emp => @<span style="color:#6b7280; font-size: 0.8rem;">@emp.HireDate.ToString("MMM dd, yyyy")</span>
        },
        new()
        {
            Header     = "Status",
            GridWidth  = "minmax(90px, 0.9fr)",
            CellTemplate = emp => @<MudChip T="string" Size="Size.Small"
                                             Color="@(emp.IsActive ? Color.Success : Color.Error)">
                @(emp.IsActive ? "Active" : "Inactive")
            </MudChip>
        },
        new()
        {
            Header     = UseEllipsisActions ? "" : "Actions",
            GridWidth  = "minmax(80px, 0.8fr)",
            HideOnMobile = true,
            CellTemplate = emp => @<text>
                @if (UseEllipsisActions)
                {
                    <div style="display:flex; justify-content: flex-end;">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary">Edit</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
                        </MudMenu>
                    </div>
                }
                else
                {
                    <div style="display:flex;gap:4px;">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"  Color="Color.Primary" Size="Size.Small" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"   Size="Size.Small" />
                    </div>
                }
            </text>
        },
    };

    private void HandleRowClick(EmployeeModel emp)
    {
        // TODO: open detail drawer / dialog
    }
}
