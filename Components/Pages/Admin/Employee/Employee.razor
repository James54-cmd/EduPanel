@page "/admin/employee"
@namespace EduPanel.Components.Pages.Admin

<div class="mb-6">
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h5" Class="font-weight-bold">Employees</MudText>
    </div>
    <div class="d-flex justify-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
            Add Employee
        </MudButton>
    </div>
</div>

<DataTable TItem="EmployeeModel"
           Items="@Employees"
           Columns="@Columns"
           Dense="true"
           PageSize="10"
           BodyHeight="calc(100vh - 20rem)"
           EmptyText="No employees found"
           OnRowClick="@HandleRowClick">
    <MobileCardTemplate Context="emp">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:6px;">
            <div style="display:flex; align-items:center; gap:10px; min-width:0;">
                <MudAvatar Size="Size.Small" Class="avatar-gradient-primary">@emp.Name.Substring(0,1)</MudAvatar>
                <div style="min-width:0;">
                    <div style="font-size:.9rem;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@emp.Name</div>
                    <div style="font-size:.75rem;color:#6b7280;">@emp.Role · @emp.Department</div>
                </div>
            </div>
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                     Dense="true">
                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary">Edit</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
            </MudMenu>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:.75rem;color:#9ca3af;">ID: @emp.Id</span>
            <MudChip T="string" Size="Size.Small" Color="@(emp.IsActive ? Color.Success : Color.Error)">
                @(emp.IsActive ? "Active" : "Inactive")
            </MudChip>
        </div>
    </MobileCardTemplate>

</DataTable>

@code {
    private bool UseEllipsisActions = true;

