@page "/dashboard"

<div class="d-flex align-center justify-space-between mb-6">
    <div class="d-flex align-center">
        <div class="d-flex align-center justify-center rounded bg-primary text-white mr-3" style="width: 32px; height: 32px;">
            <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" />
        </div>
        <MudText Typo="Typo.h5" Class="font-weight-bold">Dashboard</MudText>
    </div>
    <MudLink Href="#" Color="Color.Primary" Class="d-flex align-center text-decoration-none">
        Overview <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="ml-1" />
    </MudLink>
</div>

<MudGrid>
    <!-- Top Cards -->
    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-6 rounded-lg text-white card-gradient-pink relative overflow-hidden h-100">
            <MudText Typo="Typo.body1" Class="mb-2">Weekly Sales</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-6">$ 15,0000</MudText>
            <MudText Typo="Typo.body2">Increased by 60%</MudText>
            <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="absolute top-4 right-4 text-white" Style="opacity: 0.5; font-size: 2rem;" />
            <!-- decorative circles -->
            <div class="card-circle circle-1"></div>
            <div class="card-circle circle-2"></div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-6 rounded-lg text-white card-gradient-blue relative overflow-hidden h-100">
            <MudText Typo="Typo.body1" Class="mb-2">Weekly Orders</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-6">45,6334</MudText>
            <MudText Typo="Typo.body2">Decreased by 10%</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Bookmark" Class="absolute top-4 right-4 text-white" Style="opacity: 0.5; font-size: 2rem;" />
            <div class="card-circle circle-1"></div>
            <div class="card-circle circle-2"></div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-6 rounded-lg text-white card-gradient-green relative overflow-hidden h-100">
            <MudText Typo="Typo.body1" Class="mb-2">Visitors Online</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-6">95,5741</MudText>
            <MudText Typo="Typo.body2">Increased by 5%</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Diamond" Class="absolute top-4 right-4 text-white" Style="opacity: 0.5; font-size: 2rem;" />
            <div class="card-circle circle-1"></div>
            <div class="card-circle circle-2"></div>
        </MudPaper>
    </MudItem>

    <!-- Charts -->
    <MudItem xs="12" md="7">
        <MudPaper Elevation="0" Class="pa-6 rounded-lg h-100">
            <MudText Typo="Typo.h6" Class="mb-4 font-weight-bold">Visit And Sales Statistics</MudText>
            <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@Series" XAxisLabels="@XAxisLabels" Width="100%" Height="300px" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudPaper Elevation="0" Class="pa-6 rounded-lg h-100 relative">
            <MudText Typo="Typo.h6" Class="mb-4 font-weight-bold">Traffic Sources</MudText>
            <MudChart T="double" ChartType="ChartType.Donut" InputData="@DonutData" InputLabels="@DonutLabels" Width="100%" Height="300px" />
            
            <MudFab Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="absolute" Style="bottom: 1rem; right: 1rem;" />

            <div class="d-flex flex-column gap-2 mt-4 px-4">
                <div class="d-flex justify-space-between align-center">
                    <div class="d-flex align-center gap-2">
                        <div style="width: 12px; height: 12px; border-radius: 50%; background-color: #594ae2;"></div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Search Engines</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">30%</MudText>
                </div>
                <div class="d-flex justify-space-between align-center">
                    <div class="d-flex align-center gap-2">
                        <div style="width: 12px; height: 12px; border-radius: 50%; background-color: #00c853;"></div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Direct Click</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">30%</MudText>
                </div>
                <div class="d-flex justify-space-between align-center">
                    <div class="d-flex align-center gap-2">
                        <div style="width: 12px; height: 12px; border-radius: 50%; background-color: #ff5252;"></div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Bookmarks Click</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">40%</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<style>
    .card-gradient-pink { background: linear-gradient(135deg, #ff8a8e 0%, #ff5272 100%); }
    .card-gradient-blue { background: linear-gradient(135deg, #5eb8ff 0%, #1a73e8 100%); }
    .card-gradient-green { background: linear-gradient(135deg, #42e695 0%, #3bb2b8 100%); }
    
    .relative { position: relative; }
    .absolute { position: absolute; }
    .top-4 { top: 1.5rem; }
    .right-4 { right: 1.5rem; }
    .overflow-hidden { overflow: hidden; }
    .h-100 { height: 100%; }

    .card-circle {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
    }
    .circle-1 {
        width: 150px;
        height: 150px;
        bottom: -50px;
        right: -50px;
    }
    .circle-2 {
        width: 100px;
        height: 100px;
        bottom: -20px;
        right: 60px;
    }
</style>

@code {
    public List<ChartSeries<double>> Series = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "CHN", Data = new double[] { 40, 20, 25, 27, 46, 60, 48, 80 } },
        new ChartSeries<double>() { Name = "USA", Data = new double[] { 19, 24, 29, 13, 28, 15, 13, 16 } },
        new ChartSeries<double>() { Name = "UK",  Data = new double[] { 8, 6, 11, 13, 4, 16, 10, 16 } },
    };
    public string[] XAxisLabels = { "JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG" };

    public double[] DonutData = { 30, 30, 40 };
    public string[] DonutLabels = { "Search Engines", "Direct Click", "Bookmarks Click" };
}
