@page "/dashboard"
@using MudBlazor

<MudContainer Class="mt-6">

    <MudText Typo="Typo.h4">Dashboard</MudText>

    <MudGrid Class="mt-4">

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4">
                <MudText>Total Students</MudText>
                <MudText Typo="Typo.h5">120</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4">
                <MudText>Total Teachers</MudText>
                <MudText Typo="Typo.h5">15</MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>
