@page "/login"
@layout LoginLayout
@using EduPanel.Components.Layout

<div class="login-grid-layout" style="display: grid; grid-template-columns: 1fr; min-height: 100vh; width: 100vw; overflow: hidden; margin: 0; padding: 0; box-sizing: border-box;">
    <!-- Left Pane -->
    <div class="d-flex flex-column" style="min-height: 100vh; width: 100%; box-sizing: border-box;">
        <!-- Top Logo -->
        <div class="d-flex align-center gap-2 pa-6" style="width: 100%;">
            <a href="#" class="d-flex align-center gap-2 font-weight-bold" style="color: var(--mud-palette-text-primary); text-decoration: none; font-size: 1.1rem;">
                <div class="d-flex align-center justify-center rounded bg-primary text-white" style="width: 24px; height: 24px;">
                    <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" Style="font-size: 1rem; color: white;" />
                </div>
                <span>EduPanel Inc.</span>
            </a>
        </div>

        <!-- Centered LoginForm -->
        <div class="d-flex flex-grow-1 align-center justify-center pa-6" style="margin-top: -40px; box-sizing: border-box;">
            <div class="w-100" style="max-width: 320px;">
                <LoginForm />
            </div>
        </div>
    </div>

    <!-- Right Pane: Image (Visible only on md screens and up) -->
    <div class="right-pane-bg" style="width: 100%; height: 100vh; overflow: hidden; position: relative; display: none;">
        <img src="/login_bg.png" 
             alt="Educational geometry background" 
             style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.95);" />
    </div>
</div>

<style>
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        overflow: hidden !important;
    }
    
    @@media (min-width: 960px) {
        .login-grid-layout {
            grid-template-columns: 1fr 1fr !important;
        }
        .right-pane-bg {
            display: block !important;
        }
    }
</style>
