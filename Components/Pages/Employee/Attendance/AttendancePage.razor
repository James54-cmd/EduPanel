@page "/employee/attendance/{PageSlug}"
@namespace EduPanel.Components.Pages.Employee.Attendance
@using EduPanel.Components.Pages.Employee.Attendance.Tabs
@inject ISnackbar Snackbar

<div class="pa-4">
    <!-- Header Section -->
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl mb-6 header-card">
        <div class="d-flex align-center gap-4">
            <div class="icon-wrapper">
                <MudIcon Icon="@Details.Icon" Size="Size.Large" Color="Color.Primary" />
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold mb-1" Style="letter-spacing: -0.5px;">@Details.Title</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Details.Description</MudText>
            </div>
        </div>
    </MudPaper>

    <MudGrid>
        <DynamicComponent Type="@CurrentTabType" />
    </MudGrid>
</div>

@code {
    [Parameter]
    public string PageSlug { get; set; } = "";

    private Type CurrentTabType => PageSlug.ToLowerInvariant() switch
    {
        "inquiry" => typeof(InquiryTab),
        "schedule-calendar" => typeof(ScheduleCalendarTab),
        "change-shift" => typeof(ChangeShiftTab),
        "change-day-off" => typeof(ChangeDayOffTab),
        "time-declaration" => typeof(TimeDeclarationTab),
        "leave-ob" => typeof(LeaveOBTab),
        "leave-cancellation" => typeof(LeaveCancellationTab),
        "leave-balance" => typeof(LeaveBalanceTab),
        "overtime-application" => typeof(OvertimeApplicationTab),
        "dtr" => typeof(DTRTab),
        _ => typeof(InquiryTab)
    };

    private class PageDetails
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
    }

    private PageDetails Details => PageSlug.ToLowerInvariant() switch
    {
        "inquiry" => new() { Title = "Attendance Inquiry", Description = "View and filter your punch records, login/logout logs, and daily attendance status.", Icon = Icons.Material.Filled.Search },
        "schedule-calendar" => new() { Title = "My Schedule Calendar", Description = "Check your assigned shifts, rest days, and holiday schedule.", Icon = Icons.Material.Filled.CalendarMonth },
        "change-shift" => new() { Title = "Change Shift", Description = "Submit a request to change your scheduled shift for a specific date.", Icon = Icons.Material.Filled.PublishedWithChanges },
        "change-day-off" => new() { Title = "Change Day Off", Description = "Submit a request to exchange your rest day with another date.", Icon = Icons.Material.Filled.EventBusy },
        "time-declaration" => new() { Title = "Time Declaration", Description = "Declare missing logs or manual time entries if you forgot to clock in/out.", Icon = Icons.Material.Filled.ScheduleSend },
        "leave-ob" => new() { Title = "Leave / OB", Description = "File a leave of absence or official business trip request.", Icon = Icons.Material.Filled.TimeToLeave },
        "leave-cancellation" => new() { Title = "Leave Cancellation", Description = "Cancel a previously approved or pending leave request.", Icon = Icons.Material.Filled.CancelPresentation },
        "leave-balance" => new() { Title = "Leave Balance", Description = "Check your remaining leave credits for each leave type.", Icon = Icons.Material.Filled.Assessment },
        "overtime-application" => new() { Title = "Overtime Application", Description = "Submit an application for pre-approved overtime work.", Icon = Icons.Material.Filled.MoreTime },
        "dtr" => new() { Title = "Daily Time Record (DTR)", Description = "Review, print, or export your official Daily Time Record.", Icon = Icons.Material.Filled.ReceiptLong },
        _ => new() { Title = "Attendance Portal", Description = "Manage your schedule, leaves, and time records.", Icon = Icons.Material.Filled.AccessTime }
    };
}
