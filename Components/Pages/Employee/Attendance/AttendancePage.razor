        "change-day-off" => new() { Title = "Change Day Off", Description = "Submit a request to exchange your rest day with another date.", Icon = Icons.Material.Filled.EventBusy },
        "time-declaration" => new() { Title = "Time Declaration", Description = "Declare missing logs or manual time entries if you forgot to clock in/out.", Icon = Icons.Material.Filled.ScheduleSend },
        "leave-ob" => new() { Title = "Leave / OB", Description = "File a leave of absence or official business trip request.", Icon = Icons.Material.Filled.TimeToLeave },
        "leave-cancellation" => new() { Title = "Leave Cancellation", Description = "Cancel a previously approved or pending leave request.", Icon = Icons.Material.Filled.CancelPresentation },
        "leave-balance" => new() { Title = "Leave Balance", Description = "Check your remaining leave credits for each leave type.", Icon = Icons.Material.Filled.Assessment },
        "overtime-application" => new() { Title = "Overtime Application", Description = "Submit an application for pre-approved overtime work.", Icon = Icons.Material.Filled.MoreTime },
        "dtr" => new() { Title = "Daily Time Record (DTR)", Description = "Review, print, or export your official Daily Time Record.", Icon = Icons.Material.Filled.ReceiptLong },
        _ => new() { Title = "Attendance Portal", Description = "Manage your schedule, leaves, and time records.", Icon = Icons.Material.Filled.AccessTime }
    };

    // Helper functions for chip colors
    private Color GetStatusColor(string status) => status switch
    {
        "Present" => Color.Success,
        "Late" => Color.Error,
        "Absent" => Color.Warning,
        _ => Color.Default
    };

    private Color GetRequestStatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Pending" => Color.Warning,
        "Rejected" => Color.Error,
        "Cancelled" => Color.Default,
        _ => Color.Default
    };

    // Forms and fields bindings
    private MudForm? _changeShiftForm;
    private DateTime? _shiftRequestDate = DateTime.Today;
    private string _currentShift = "08:00 AM - 05:00 PM";
    private string _proposedShift = "06:00 AM - 03:00 PM";
    private string _shiftReason = "";

    private DateTime? _originalDayOff = DateTime.Today;
    private DateTime? _proposedDayOff = DateTime.Today.AddDays(1);
    private string _dayOffReason = "";

    private DateTime? _declDate = DateTime.Today;
    private string _declType = "Time In";
    private TimeSpan? _declTime = new TimeSpan(8, 0, 0);
    private string _declReason = "";

    private string _leaveType = "Vacation Leave";
    private DateTime? _leaveStart = DateTime.Today.AddDays(7);
    private DateTime? _leaveEnd = DateTime.Today.AddDays(8);
    private string _leaveReason = "";

    private DateTime? _otDate = DateTime.Today;
    private TimeSpan? _otStart = new TimeSpan(17, 0, 0);
    private TimeSpan? _otEnd = new TimeSpan(19, 0, 0);
    private string _otPurpose = "";

    // Mock Models
    public class AttendanceLog
    {
        public DateTime Date { get; set; }
        public string Shift { get; set; } = "";
        public DateTime? FirstIn { get; set; }
        public DateTime? LastOut { get; set; }
        public int LateMinutes { get; set; }
        public int UndertimeMinutes { get; set; }
        public string Status { get; set; } = "";
    }

    public class ShiftRequest
    {
        public DateTime DateRequested { get; set; }
        public DateTime TargetDate { get; set; }
        public string CurrentShift { get; set; } = "";
        public string ProposedShift { get; set; } = "";
        public string Status { get; set; } = "";
    }

    public class DayOffRequest
    {
        public DateTime DateRequested { get; set; }
        public DateTime OriginalDayOff { get; set; }
        public DateTime ProposedDayOff { get; set; }
        public string Status { get; set; } = "";
    }

    public class TimeDeclarationRequest
    {
        public DateTime DateRequested { get; set; }
        public DateTime TargetDate { get; set; }
        public string LogType { get; set; } = "";
        public TimeSpan ActualTime { get; set; }
        public string Status { get; set; } = "";
    }

    public class LeaveRequestModel
    {
        public string Type { get; set; } = "";
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public int TotalDays => (End - Start).Days + 1;
        public string Status { get; set; } = "";
    }

    public class OvertimeRequestModel
    {
        public DateTime Date { get; set; }
        public TimeSpan Start { get; set; }
        public TimeSpan End { get; set; }
        public double Hours => (End - Start).TotalHours;
        public string Status { get; set; } = "";
    }

    // Mock Data Pools
    private List<AttendanceLog> MockAttendanceLogs = new()
    {
        new() { Date = DateTime.Today.AddDays(-1), Shift = "08:00 AM - 05:00 PM", FirstIn = DateTime.Today.AddDays(-1).AddHours(7).AddMinutes(52), LastOut = DateTime.Today.AddDays(-1).AddHours(17).AddMinutes(5), LateMinutes = 0, UndertimeMinutes = 0, Status = "Present" },
        new() { Date = DateTime.Today.AddDays(-2), Shift = "08:00 AM - 05:00 PM", FirstIn = DateTime.Today.AddDays(-2).AddHours(8).AddMinutes(12), LastOut = DateTime.Today.AddDays(-2).AddHours(17).AddMinutes(0), LateMinutes = 12, UndertimeMinutes = 0, Status = "Late" },
        new() { Date = DateTime.Today.AddDays(-3), Shift = "08:00 AM - 05:00 PM", FirstIn = DateTime.Today.AddDays(-3).AddHours(7).AddMinutes(55), LastOut = DateTime.Today.AddDays(-3).AddHours(16).AddMinutes(45), LateMinutes = 0, UndertimeMinutes = 15, Status = "Present" },
        new() { Date = DateTime.Today.AddDays(-4), Shift = "08:00 AM - 05:00 PM", FirstIn = null, LastOut = null, LateMinutes = 0, UndertimeMinutes = 0, Status = "Absent" },
        new() { Date = DateTime.Today.AddDays(-5), Shift = "08:00 AM - 05:00 PM", FirstIn = DateTime.Today.AddDays(-5).AddHours(7).AddMinutes(58), LastOut = DateTime.Today.AddDays(-5).AddHours(17).AddMinutes(10), LateMinutes = 0, UndertimeMinutes = 0, Status = "Present" }
    };

    private List<ShiftRequest> ShiftChangeRequests = new()
    {
        new() { DateRequested = DateTime.Today.AddDays(-2), TargetDate = DateTime.Today.AddDays(3), CurrentShift = "08:00 AM - 05:00 PM", ProposedShift = "06:00 AM - 03:00 PM", Status = "Pending" },
        new() { DateRequested = DateTime.Today.AddDays(-10), TargetDate = DateTime.Today.AddDays(-8), CurrentShift = "08:00 AM - 05:00 PM", ProposedShift = "10:00 AM - 07:00 PM", Status = "Approved" }
    };

    private List<DayOffRequest> DayOffRequests = new()
    {
        new() { DateRequested = DateTime.Today.AddDays(-5), OriginalDayOff = DateTime.Today.AddDays(6), ProposedDayOff = DateTime.Today.AddDays(7), Status = "Approved" }
    };

    private List<TimeDeclarationRequest> TimeDeclarations = new()
    {
        new() { DateRequested = DateTime.Today.AddDays(-1), TargetDate = DateTime.Today.AddDays(-1), LogType = "Time In", ActualTime = new TimeSpan(8, 0, 0), Status = "Pending" }
    };

    private List<LeaveRequestModel> LeaveRequests = new()
    {
        new() { Type = "Vacation Leave", Start = DateTime.Today.AddDays(10), End = DateTime.Today.AddDays(12), Status = "Approved" },
        new() { Type = "Sick Leave", Start = DateTime.Today.AddDays(-15), End = DateTime.Today.AddDays(-15), Status = "Approved" },
        new() { Type = "Official Business (OB)", Start = DateTime.Today.AddDays(2), End = DateTime.Today.AddDays(2), Status = "Pending" }
    };

    private List<OvertimeRequestModel> OvertimeRequests = new()
    {
        new() { Date = DateTime.Today.AddDays(-3), Start = new TimeSpan(17, 0, 0), End = new TimeSpan(18, 30, 0), Status = "Approved" },
        new() { Date = DateTime.Today.AddDays(1), Start = new TimeSpan(17, 0, 0), End = new TimeSpan(19, 0, 0), Status = "Pending" }
    };

    // Submissions handling
    private void SubmitShiftChange()
    {
        if (_shiftRequestDate == null || string.IsNullOrWhiteSpace(_shiftReason))
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        ShiftChangeRequests.Insert(0, new()
        {
            DateRequested = DateTime.Today,
            TargetDate = _shiftRequestDate.Value,
            CurrentShift = _currentShift,
            ProposedShift = _proposedShift,
            Status = "Pending"
        });

        _shiftReason = "";
        Snackbar.Add("Shift change request submitted successfully!", Severity.Success);
    }

    private void SubmitDayOffChange()
    {
        if (_originalDayOff == null || _proposedDayOff == null || string.IsNullOrWhiteSpace(_dayOffReason))
