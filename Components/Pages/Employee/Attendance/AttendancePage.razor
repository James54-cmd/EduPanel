@page "/employee/attendance/{PageSlug}"
@namespace EduPanel.Components.Pages.Employee.Attendance
@inject ISnackbar Snackbar

<div class="pa-4">
    <!-- Breadcrumb-like indicator -->
    <div class="d-flex align-center gap-2 mb-2">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Employee Portal</MudText>
        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="mud-text-secondary" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">Attendance</MudText>
    </div>

    <!-- Header Section -->
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl mb-6 header-card">
        <div class="d-flex align-center gap-4">
            <div class="icon-wrapper">
                <MudIcon Icon="@Details.Icon" Size="Size.Large" Color="Color.Primary" />
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold mb-1" Style="letter-spacing: -0.5px;">@Details.Title</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Details.Description</MudText>
            </div>
        </div>
    </MudPaper>

    <MudGrid>
        @if (PageSlug == "inquiry")
        {
            <!-- Attendance Inquiry -->
            <MudItem xs="12">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <div class="d-flex flex-wrap gap-4 align-center justify-space-between mb-4">
                        <div class="d-flex gap-2">
                            <MudDateRangePicker Label="Select Date Range" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 260px;" />
                            <MudSelect T="string" Label="Status" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 140px;" @bind-Value="_statusFilter">
                                <MudSelectItem Value="@("All")">All Statuses</MudSelectItem>
                                <MudSelectItem Value="@("Present")">Present</MudSelectItem>
                                <MudSelectItem Value="@("Late")">Late</MudSelectItem>
                                <MudSelectItem Value="@("Absent")">Absent</MudSelectItem>
                            </MudSelect>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">Filter Logs</MudButton>
                    </div>

                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Scheduled Shift</th>
                                <th>First In</th>
                                <th>Last Out</th>
                                <th>Late (min)</th>
                                <th>Undertime (min)</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in MockAttendanceLogs.Where(l => _statusFilter == "All" || l.Status == _statusFilter))
                            {
                                <tr>
                                    <td>@log.Date.ToString("MMMM dd, yyyy")</td>
                                    <td>@log.Shift</td>
                                    <td>@(log.FirstIn?.ToString("hh:mm tt") ?? "--:--")</td>
                                    <td>@(log.LastOut?.ToString("hh:mm tt") ?? "--:--")</td>
                                    <td>
                                        @if (log.LateMinutes > 0)
                                        {
                                            <span class="text-error font-weight-bold">@log.LateMinutes min</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (log.UndertimeMinutes > 0)
                                        {
                                            <span class="text-warning font-weight-bold">@log.UndertimeMinutes min</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">0</span>
                                        }
                                    </td>
                                    <td>
                                        <MudChip T="string" Color="@GetStatusColor(log.Status)" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold">@log.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "schedule-calendar")
        {
            <!-- Schedule Calendar -->
            <MudItem xs="12">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <div class="d-flex align-center justify-space-between mb-6">
                        <div class="d-flex align-center gap-2">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Variant="Variant.Outlined" Size="Size.Small" />
                            <MudText Typo="Typo.h6" Class="font-weight-bold">June 2026</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Variant="Variant.Outlined" Size="Size.Small" />
                        </div>
                        <div class="d-flex gap-4">
                            <div class="d-flex align-center gap-1"><span class="legend-color-dot" style="background-color: var(--mud-palette-primary);"></span> <MudText Typo="Typo.caption">Regular Shift</MudText></div>
                            <div class="d-flex align-center gap-1"><span class="legend-color-dot" style="background-color: var(--mud-palette-secondary);"></span> <MudText Typo="Typo.caption">Rest Day</MudText></div>
                            <div class="d-flex align-center gap-1"><span class="legend-color-dot" style="background-color: var(--mud-palette-success);"></span> <MudText Typo="Typo.caption">Holiday</MudText></div>
                        </div>
                    </div>

                    <div class="calendar-grid">
                        <!-- Days of Week -->
                        <div class="calendar-header">Sun</div>
                        <div class="calendar-header">Mon</div>
                        <div class="calendar-header">Tue</div>
                        <div class="calendar-header">Wed</div>
                        <div class="calendar-header">Thu</div>
                        <div class="calendar-header">Fri</div>
                        <div class="calendar-header">Sat</div>

                        <!-- Calendar Days -->
                        @for (int i = 1; i <= 30; i++)
                        {
                            var day = i;
                            var isRestDay = (day % 7 == 0 || day % 7 == 6);
                            var isHoliday = (day == 12); // June 12 Independence Day
                            var cellClass = isRestDay ? "calendar-cell rest-day" : isHoliday ? "calendar-cell holiday" : "calendar-cell work-day";

                            <div class="@cellClass">
                                <span class="day-number">@day</span>
                                <div class="cell-content">
                                    @if (isHoliday)
                                    {
                                        <div class="cell-label-holiday">Independence Day</div>
                                        <div class="cell-time">No Work</div>
                                    }
                                    else if (isRestDay)
                                    {
                                        <div class="cell-label-rest">Rest Day</div>
                                    }
                                    else
                                    {
                                        <div class="cell-label-work">Regular Shift</div>
                                        <div class="cell-time">08:00 AM - 05:00 PM</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "change-shift")
        {
            <!-- Change Shift -->
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">New Request</MudText>
                    <MudForm @ref="_changeShiftForm">
                        <MudDatePicker Label="Target Date" @bind-Date="_shiftRequestDate" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <MudSelect T="string" Label="Current Shift" @bind-Value="_currentShift" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem Value="@("08:00 AM - 05:00 PM")">Regular Shift (08:00 AM - 05:00 PM)</MudSelectItem>
                        </MudSelect>
                        <MudSelect T="string" Label="Proposed Shift" @bind-Value="_proposedShift" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem Value="@("06:00 AM - 03:00 PM")">Early Shift (06:00 AM - 03:00 PM)</MudSelectItem>
                            <MudSelectItem Value="@("10:00 AM - 07:00 PM")">Late Shift (10:00 AM - 07:00 PM)</MudSelectItem>
                            <MudSelectItem Value="@("10:00 PM - 07:00 AM")">Night Shift (10:00 PM - 07:00 AM)</MudSelectItem>
                        </MudSelect>
                        <MudTextField T="string" Label="Reason" @bind-Value="_shiftReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitShiftChange">Submit Request</MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Request History</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Date Requested</th>
                                <th>Target Date</th>
                                <th>Details</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in ShiftChangeRequests)
                            {
                                <tr>
                                    <td>@req.DateRequested.ToString("MM/dd/yyyy")</td>
                                    <td>@req.TargetDate.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="text-caption mud-text-secondary">From: @req.CurrentShift</span>
                                            <span class="text-caption font-weight-bold">To: @req.ProposedShift</span>
                                        </div>
                                    </td>
                                    <td>
                                        <MudChip T="string" Color="@GetRequestStatusColor(req.Status)" Size="Size.Small" Variant="Variant.Filled">@req.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "change-day-off")
        {
            <!-- Change Day Off -->
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">New Request</MudText>
                    <MudForm>
                        <MudDatePicker Label="Original Day Off" @bind-Date="_originalDayOff" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <MudDatePicker Label="Proposed New Day Off" @bind-Date="_proposedDayOff" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <MudTextField T="string" Label="Reason" @bind-Value="_dayOffReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitDayOffChange">Submit Request</MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Request History</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Date Requested</th>
                                <th>Original Day Off</th>
                                <th>Proposed Day Off</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in DayOffRequests)
                            {
                                <tr>
                                    <td>@req.DateRequested.ToString("MM/dd/yyyy")</td>
                                    <td>@req.OriginalDayOff.ToString("MM/dd/yyyy")</td>
                                    <td>@req.ProposedDayOff.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <MudChip T="string" Color="@GetRequestStatusColor(req.Status)" Size="Size.Small" Variant="Variant.Filled">@req.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "time-declaration")
        {
            <!-- Time Declaration -->
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Declare Missing Time</MudText>
                    <MudForm>
                        <MudDatePicker Label="Date of Log" @bind-Date="_declDate" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <MudSelect T="string" Label="Log Type" @bind-Value="_declType" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem Value="@("Time In")">Time In</MudSelectItem>
                            <MudSelectItem Value="@("Time Out")">Time Out</MudSelectItem>
                        </MudSelect>
                        <MudTimePicker Label="Actual Log Time" @bind-Time="_declTime" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <MudTextField T="string" Label="Reason / Remarks" @bind-Value="_declReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitTimeDeclaration">Submit Declaration</MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Declaration History</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Date Filed</th>
                                <th>Target Date</th>
                                <th>Log Details</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in TimeDeclarations)
                            {
                                <tr>
                                    <td>@req.DateRequested.ToString("MM/dd/yyyy")</td>
                                    <td>@req.TargetDate.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="font-weight-bold">@req.LogType</span>
                                            <span class="text-caption mud-text-secondary">Time: @req.ActualTime.ToString(@"hh\:mm")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <MudChip T="string" Color="@GetRequestStatusColor(req.Status)" Size="Size.Small" Variant="Variant.Filled">@req.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "leave-ob")
        {
            <!-- Leave / OB Request -->
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">File Leave / Official Business</MudText>
                    <MudForm>
                        <MudSelect T="string" Label="Application Type" @bind-Value="_leaveType" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                            <MudSelectItem Value="@("Vacation Leave")">Vacation Leave</MudSelectItem>
                            <MudSelectItem Value="@("Sick Leave")">Sick Leave</MudSelectItem>
                            <MudSelectItem Value="@("Official Business (OB)")">Official Business (OB)</MudSelectItem>
                            <MudSelectItem Value="@("Emergency Leave")">Emergency Leave</MudSelectItem>
                        </MudSelect>
                        <div class="d-flex gap-2 mb-3">
                            <MudDatePicker Label="Start Date" @bind-Date="_leaveStart" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
                            <MudDatePicker Label="End Date" @bind-Date="_leaveEnd" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
                        </div>
                        <MudTextField T="string" Label="Reason" @bind-Value="_leaveReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitLeaveRequest">Submit Request</MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Leave & OB History</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Dates</th>
                                <th>Days</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var leave in LeaveRequests)
                            {
                                <tr>
                                    <td class="font-weight-bold">@leave.Type</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="text-body2">@leave.Start.ToString("MM/dd/yyyy") - @leave.End.ToString("MM/dd/yyyy")</span>
                                        </div>
                                    </td>
                                    <td>@leave.TotalDays</td>
                                    <td>
                                        <MudChip T="string" Color="@GetRequestStatusColor(leave.Status)" Size="Size.Small" Variant="Variant.Filled">@leave.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "leave-cancellation")
        {
            <!-- Leave Cancellation -->
            <MudItem xs="12">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Approved Upcoming Leaves</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Leave Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Total Days</th>
                                <th>Current Status</th>
                                <th style="text-align: right;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!LeaveRequests.Any(l => l.Status == "Approved"))
                            {
                                <tr>
                                    <td colspan="6" class="text-center pa-4 mud-text-secondary">No approved upcoming leaves available to cancel.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var leave in LeaveRequests.Where(l => l.Status == "Approved"))
                                {
                                    <tr>
                                        <td class="font-weight-bold">@leave.Type</td>
                                        <td>@leave.Start.ToString("MMMM dd, yyyy")</td>
                                        <td>@leave.End.ToString("MMMM dd, yyyy")</td>
                                        <td>@leave.TotalDays days</td>
                                        <td>
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Approved</MudChip>
                                        </td>
                                        <td style="text-align: right;">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="() => CancelLeave(leave)">Cancel Leave</MudButton>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "leave-balance")
        {
            <!-- Leave Balance -->
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Vacation Leave</MudText>
                    <MudProgressCircular Color="Color.Primary" Value="75" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
                        <MudText Typo="Typo.h5" Class="font-weight-bold">9 / 12</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Sick Leave</MudText>
                    <MudProgressCircular Color="Color.Success" Value="60" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
                        <MudText Typo="Typo.h5" Class="font-weight-bold">6 / 10</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Emergency Leave</MudText>
                    <MudProgressCircular Color="Color.Warning" Value="100" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
                        <MudText Typo="Typo.h5" Class="font-weight-bold">5 / 5</MudText>
                    </MudProgressCircular>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "overtime-application")
        {
            <!-- Overtime Application -->
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">File Overtime (OT)</MudText>
                    <MudForm>
                        <MudDatePicker Label="OT Date" @bind-Date="_otDate" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                        <div class="d-flex gap-2 mb-3">
                            <MudTimePicker Label="Start Time" @bind-Time="_otStart" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
                            <MudTimePicker Label="End Time" @bind-Time="_otEnd" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
                        </div>
                        <MudTextField T="string" Label="OT Purpose / Project Name" @bind-Value="_otPurpose" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitOvertimeRequest">Submit Application</MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Overtime History</MudText>
                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>OT Date</th>
                                <th>Time Range</th>
                                <th>Hours</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ot in OvertimeRequests)
                            {
                                <tr>
                                    <td>@ot.Date.ToString("MM/dd/yyyy")</td>
                                    <td>@ot.Start.ToString(@"hh\:mm") - @ot.End.ToString(@"hh\:mm")</td>
                                    <td>@ot.Hours.ToString("0.0") hrs</td>
                                    <td>
                                        <MudChip T="string" Color="@GetRequestStatusColor(ot.Status)" Size="Size.Small" Variant="Variant.Filled">@ot.Status</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
        else if (PageSlug == "dtr")
        {
            <!-- DTR (Daily Time Record) -->
            <MudItem xs="12">
                <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
                    <div class="d-flex flex-wrap align-center justify-space-between gap-4 mb-4">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Timesheet - June 2026</MudText>
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download">Export CSV</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print">Print DTR</MudButton>
                        </div>
                    </div>

                    <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Shift Schedule</th>
                                <th>Clock In</th>
                                <th>Clock Out</th>
                                <th>Late (m)</th>
                                <th>Under (m)</th>
                                <th>OT (h)</th>
                                <th>Total Hrs</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 1; i <= 10; i++)
                            {
                                var day = i;
                                var isRest = (day == 6 || day == 7);
                                <tr>
                                    <td class="font-weight-bold">June @day, 2026</td>
                                    <td>@(isRest ? "REST DAY" : "08:00 AM - 05:00 PM")</td>
                                    <td>@(isRest ? "--" : "07:54 AM")</td>
                                    <td>@(isRest ? "--" : "05:05 PM")</td>
                                    <td>@(isRest ? "0" : "0")</td>
                                    <td>@(isRest ? "0" : "0")</td>
                                    <td>@(isRest ? "0.0" : (day == 3 ? "1.5" : "0.0"))</td>
                                    <td>@(isRest ? "0" : (day == 3 ? "9.5" : "8.0"))</td>
                                    <td>
                                        <MudChip T="string" Color="@(isRest ? Color.Secondary : Color.Success)" Size="Size.Small" Variant="Variant.Filled">
                                            @(isRest ? "Rest Day" : "Present")
                                        </MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</div>

@code {
    [Parameter]
