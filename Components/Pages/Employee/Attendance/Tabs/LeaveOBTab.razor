@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs
@inject ISnackbar Snackbar

<MudItem xs="12" md="5">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">File Leave / Official Business</MudText>
        <MudForm>
            <MudSelect T="string" Label="Application Type" @bind-Value="_leaveType" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("Vacation Leave")">Vacation Leave</MudSelectItem>
                <MudSelectItem Value="@("Sick Leave")">Sick Leave</MudSelectItem>
                <MudSelectItem Value="@("Official Business (OB)")">Official Business (OB)</MudSelectItem>
                <MudSelectItem Value="@("Emergency Leave")">Emergency Leave</MudSelectItem>
            </MudSelect>
            <div class="d-flex gap-2 mb-3">
                <MudDatePicker Label="Start Date" @bind-Date="_leaveStart" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
                <MudDatePicker Label="End Date" @bind-Date="_leaveEnd" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 50%;" />
            </div>
            <MudTextField T="string" Label="Reason" @bind-Value="_leaveReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitLeaveRequest">Submit Request</MudButton>
        </MudForm>
    </MudPaper>
</MudItem>
<MudItem xs="12" md="7">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Leave & OB History</MudText>
        <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Dates</th>
                    <th>Days</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var leave in LeaveRequests)
                {
                    <tr>
                        <td class="font-weight-bold">@leave.Type</td>
                        <td>
                            <div class="d-flex flex-column">
                                <span class="text-body2">@leave.Start.ToString("MM/dd/yyyy") - @leave.End.ToString("MM/dd/yyyy")</span>
                            </div>
                        </td>
                        <td>@leave.TotalDays</td>
                        <td>
                            <MudChip T="string" Color="@GetRequestStatusColor(leave.Status)" Size="Size.Small" Variant="Variant.Filled">@leave.Status</MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
</MudItem>

@code {
    private string _leaveType = "Vacation Leave";
    private DateTime? _leaveStart = DateTime.Today.AddDays(7);
    private DateTime? _leaveEnd = DateTime.Today.AddDays(8);
    private string _leaveReason = "";

    private Color GetRequestStatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Pending" => Color.Warning,
        "Rejected" => Color.Error,
        "Cancelled" => Color.Default,
        _ => Color.Default
    };

    public class LeaveRequestModel
    {
        public string Type { get; set; } = "";
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public int TotalDays => (End - Start).Days + 1;
        public string Status { get; set; } = "";
    }

    private List<LeaveRequestModel> LeaveRequests = new()
    {
        new() { Type = "Vacation Leave", Start = DateTime.Today.AddDays(10), End = DateTime.Today.AddDays(12), Status = "Approved" },
        new() { Type = "Sick Leave", Start = DateTime.Today.AddDays(-15), End = DateTime.Today.AddDays(-15), Status = "Approved" },
        new() { Type = "Official Business (OB)", Start = DateTime.Today.AddDays(2), End = DateTime.Today.AddDays(2), Status = "Pending" }
    };

    private void SubmitLeaveRequest()
    {
        if (_leaveStart == null || _leaveEnd == null || string.IsNullOrWhiteSpace(_leaveReason))
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        LeaveRequests.Insert(0, new()
        {
            Type = _leaveType,
            Start = _leaveStart.Value,
            End = _leaveEnd.Value,
            Status = "Pending"
        });

        _leaveReason = "";
        Snackbar.Add("Leave / OB application submitted successfully!", Severity.Success);
    }
}
