@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs
@inject ISnackbar Snackbar

<MudItem xs="12" md="5">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">New Request</MudText>
        <MudForm>
            <MudDatePicker Label="Original Day Off" @bind-Date="_originalDayOff" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
            <MudDatePicker Label="Proposed New Day Off" @bind-Date="_proposedDayOff" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField T="string" Label="Reason" @bind-Value="_dayOffReason" Required="true" Lines="3" Variant="Variant.Outlined" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitDayOffChange">Submit Request</MudButton>
        </MudForm>
    </MudPaper>
</MudItem>
<MudItem xs="12" md="7">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl h-100">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Request History</MudText>
        <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
            <thead>
                <tr>
                    <th>Date Requested</th>
                    <th>Original Day Off</th>
                    <th>Proposed Day Off</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in DayOffRequests)
                {
                    <tr>
                        <td>@req.DateRequested.ToString("MM/dd/yyyy")</td>
                        <td>@req.OriginalDayOff.ToString("MM/dd/yyyy")</td>
                        <td>@req.ProposedDayOff.ToString("MM/dd/yyyy")</td>
                        <td>
                            <MudChip T="string" Color="@GetRequestStatusColor(req.Status)" Size="Size.Small" Variant="Variant.Filled">@req.Status</MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
</MudItem>

@code {
    private DateTime? _originalDayOff = DateTime.Today;
    private DateTime? _proposedDayOff = DateTime.Today.AddDays(1);
    private string _dayOffReason = "";

    private Color GetRequestStatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Pending" => Color.Warning,
        "Rejected" => Color.Error,
        "Cancelled" => Color.Default,
        _ => Color.Default
    };

    private class DayOffRequest
    {
        public DateTime DateRequested { get; set; }
        public DateTime OriginalDayOff { get; set; }
        public DateTime ProposedDayOff { get; set; }
        public string Status { get; set; } = "";
    }

    private List<DayOffRequest> DayOffRequests = new()
    {
        new() { DateRequested = DateTime.Today.AddDays(-5), OriginalDayOff = DateTime.Today.AddDays(6), ProposedDayOff = DateTime.Today.AddDays(7), Status = "Approved" }
    };

    private void SubmitDayOffChange()
    {
        if (_originalDayOff == null || _proposedDayOff == null || string.IsNullOrWhiteSpace(_dayOffReason))
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        DayOffRequests.Insert(0, new()
        {
            DateRequested = DateTime.Today,
            OriginalDayOff = _originalDayOff.Value,
            ProposedDayOff = _proposedDayOff.Value,
            Status = "Pending"
        });

        _dayOffReason = "";
        Snackbar.Add("Day off swap request submitted successfully!", Severity.Success);
    }
}
