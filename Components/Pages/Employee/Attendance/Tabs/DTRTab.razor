@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs

<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
        <div class="d-flex flex-wrap align-center justify-space-between gap-4 mb-4">
            <MudText Typo="Typo.h6" Class="font-weight-bold">Timesheet - June 2026</MudText>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download">Export CSV</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print">Print DTR</MudButton>
            </div>
        </div>

        <MudSimpleTable Hover="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Shift Schedule</th>
                    <th>Clock In</th>
                    <th>Clock Out</th>
                    <th>Late (m)</th>
                    <th>Under (m)</th>
                    <th>OT (h)</th>
                    <th>Total Hrs</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 1; i <= 10; i++)
                {
                    var day = i;
                    var isRest = (day == 6 || day == 7);
                    <tr>
                        <td class="font-weight-bold">June @day, 2026</td>
                        <td>@(isRest ? "REST DAY" : "08:00 AM - 05:00 PM")</td>
                        <td>@(isRest ? "--" : "07:54 AM")</td>
                        <td>@(isRest ? "--" : "05:05 PM")</td>
                        <td>@(isRest ? "0" : "0")</td>
                        <td>@(isRest ? "0" : "0")</td>
                        <td>@(isRest ? "0.0" : (day == 3 ? "1.5" : "0.0"))</td>
                        <td>@(isRest ? "0" : (day == 3 ? "9.5" : "8.0"))</td>
                        <td>
                            <MudChip T="string" Color="@(isRest ? Color.Secondary : Color.Success)" Size="Size.Small" Variant="Variant.Filled">
                                @(isRest ? "Rest Day" : "Present")
                            </MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
</MudItem>

