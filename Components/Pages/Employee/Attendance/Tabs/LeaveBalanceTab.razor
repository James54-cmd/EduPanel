@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs

<MudItem xs="12" md="4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Vacation Leave</MudText>
        <MudProgressCircular Color="Color.Primary" Value="75" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
            <MudText Typo="Typo.h5" Class="font-weight-bold">9 / 12</MudText>
        </MudProgressCircular>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
    </MudPaper>
</MudItem>
<MudItem xs="12" md="4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Sick Leave</MudText>
        <MudProgressCircular Color="Color.Success" Value="60" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
            <MudText Typo="Typo.h5" Class="font-weight-bold">6 / 10</MudText>
        </MudProgressCircular>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
    </MudPaper>
</MudItem>
<MudItem xs="12" md="4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl text-center flex-column justify-center align-center">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Emergency Leave</MudText>
        <MudProgressCircular Color="Color.Warning" Value="100" Size="Size.Large" StrokeWidth="8" Style="height:120px; width:120px;" Class="my-4">
            <MudText Typo="Typo.h5" Class="font-weight-bold">5 / 5</MudText>
        </MudProgressCircular>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Days Available</MudText>
    </MudPaper>
</MudItem>

