@code {
    private string _searchSummary = "";
    
    private DtrSummary? _selectedSummaryValue;
    private DtrSummary? _selectedSummary
    {
        get => _selectedSummaryValue;
        set
        {
            if (_selectedSummaryValue != value)
            {
                _selectedSummaryValue = value;
                if (value != null)
                {
                    GenerateDetailsFor(value);
                }
            }
        }
    }

    private List<DtrDetail> _details = new();

    // ── Data Models ──
    private class DtrSummary
    {
        public string EmployeeNo { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string DtrCutOff { get; set; } = "";
        public decimal ReqHrs { get; set; }
        public decimal HrsWork { get; set; }
        public decimal PaidLeave { get; set; }
        public decimal OT { get; set; }
        public decimal OT8 { get; set; }
        public decimal NP { get; set; }
        public decimal NP8 { get; set; }
        public decimal Absent { get; set; }
        public decimal Late { get; set; }
        public decimal Undertime { get; set; }
        public decimal ActualLate { get; set; }
        public decimal ActualUndertime { get; set; }
    }

    private class DtrDetail
    {
        public string Date { get; set; } = "";
        public string Day { get; set; } = "";
        public string ShiftCode { get; set; } = "";
        public string DType { get; set; } = "";
        public decimal ReqHrs { get; set; }
        public string In1 { get; set; } = "";
        public string Out1 { get; set; } = "";
        public string In2 { get; set; } = "";
        public string Out2 { get; set; } = "";
        public string OTIn1 { get; set; } = "";
        public string OTOut1 { get; set; } = "";
        public string OTIn2 { get; set; } = "";
        public string OTOut2 { get; set; } = "";
        public decimal WorkHrs { get; set; }
        public decimal OT { get; set; }
        public decimal OT8 { get; set; }
        public decimal NP { get; set; }
        public decimal NP8 { get; set; }
        public decimal Absent { get; set; }
        public decimal Late { get; set; }
        public decimal Undertime { get; set; }
        public decimal ActualLate { get; set; }
        public decimal ActualUndertime { get; set; }
        public string ChargedTo { get; set; } = "";
        public decimal LeaveHrs { get; set; }
    }

    // ── Sample Data ──
    private readonly List<DtrSummary> _summaries = new()
    {
        new()
        {
            EmployeeNo = "142",
            EmployeeName = "Damaso, James Fanuel N.",
            DtrCutOff = "05/23/2026 - 06/08/2026",
            ReqHrs = 0,
            HrsWork = 0,
            PaidLeave = 0,
            OT = 0,
            OT8 = 0,
            NP = 0,
            NP8 = 0,
            Absent = 0,
            Late = 0,
            Undertime = 0,
            ActualLate = 0,
            ActualUndertime = 0
        }
    };

    protected override void OnInitialized()
    {
        _selectedSummary = _summaries.FirstOrDefault();
    }

    private void GenerateDetailsFor(DtrSummary summary)
    {
        _details.Clear();
        var startDate = new DateTime(2026, 5, 23);
        var endDate = new DateTime(2026, 6, 8);

        for (var date = startDate; date <= endDate; date = date.AddDays(1))
        {
            _details.Add(new DtrDetail
            {
                Date = date.ToString("MM/dd/yyyy"),
                Day = date.ToString("ddd"),
                ShiftCode = "",
                DType = "RWD",
                ReqHrs = 0,
                In1 = "",
                Out1 = "",
                In2 = "",
                Out2 = "",
                OTIn1 = "",
                OTOut1 = "",
                OTIn2 = "",
                OTOut2 = "",
                WorkHrs = 0,
                OT = 0,
                OT8 = 0,
                NP = 0,
                NP8 = 0,
                Absent = 0,
                Late = 0,
                Undertime = 0,
                ActualLate = 0,
                ActualUndertime = 0,
                ChargedTo = "",
                LeaveHrs = 0
            });
        }
    }

    private bool FilterSummary(DtrSummary summary)
    {
        if (string.IsNullOrWhiteSpace(_searchSummary)) return true;
        if (summary.EmployeeName.Contains(_searchSummary, StringComparison.OrdinalIgnoreCase)) return true;
        if (summary.EmployeeNo.Contains(_searchSummary, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }
}
