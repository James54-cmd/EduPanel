@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs

<!-- DTR Summary Table (Master) -->
<MudItem xs="12" Class="mb-4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <MudTable Items="@_summaries" Dense="true" Hover="true" Bordered="true" Striped="false"
                  Filter="new Func<DtrSummary,bool>(FilterSummary)" @bind-SelectedItem="_selectedSummary"
                  Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden" HorizontalScrollbar="true">
            <ToolBarContent>
                <MudIcon Icon="@Icons.Material.Filled.Summarize" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">DTR Summary</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchSummary" Placeholder="Enter text to search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="max-width: 280px;"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Employee No.</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Employee Name</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">DTR Cut-off</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Req.<br/>Hrs</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Hrs<br/>Work</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Paid<br/>Leave</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">OT</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">OT8</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">NP</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">NP8</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Absent</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Late</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Undertime</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Actual<br/>Late</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Actual<br/>Undertime</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Details</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Work<br/>Allocation</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Employee No." Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.EmployeeNo</MudTd>
                <MudTd DataLabel="Employee Name" Class="font-weight-medium" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; color: var(--mud-palette-primary);">@context.EmployeeName</MudTd>
                <MudTd DataLabel="DTR Cut-off" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.DtrCutOff</MudTd>
                <MudTd DataLabel="Req. Hrs" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.ReqHrs.ToString("0.##")</MudTd>
                <MudTd DataLabel="Hrs Work" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.HrsWork.ToString("0.##")</MudTd>
                <MudTd DataLabel="Paid Leave" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.PaidLeave.ToString("0.##")</MudTd>
                <MudTd DataLabel="OT" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.OT.ToString("0.##")</MudTd>
                <MudTd DataLabel="OT8" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.OT8.ToString("0.##")</MudTd>
                <MudTd DataLabel="NP" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.NP.ToString("0.##")</MudTd>
                <MudTd DataLabel="NP8" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.NP8.ToString("0.##")</MudTd>
                <MudTd DataLabel="Absent" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.Absent.ToString("0.##")</MudTd>
                <MudTd DataLabel="Late" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.Late.ToString("0.##")</MudTd>
                <MudTd DataLabel="Undertime" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.Undertime.ToString("0.##")</MudTd>
                <MudTd DataLabel="Actual Late" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.ActualLate.ToString("0.##")</MudTd>
                <MudTd DataLabel="Actual Undertime" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.ActualUndertime.ToString("0.##")</MudTd>
                <MudTd DataLabel="Details" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Size="Size.Small" Color="Color.Primary" />
                </MudTd>
                <MudTd DataLabel="Work Allocation" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Default" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudItem>

