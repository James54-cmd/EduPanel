@namespace EduPanel.Components.Pages.Employee.Attendance.Tabs
@using Heron.MudCalendar

<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-xl">
        <MudCalendar T="CustomCalendarItem" Items="_events" ShowDay="false" ShowWeek="false">
            <CellTemplate>
                <div class="@($"pa-1 rounded text-white {context.CssClass}")" style="font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 2px;">
                    @context.Text
                </div>
            </CellTemplate>
        </MudCalendar>
    </MudPaper>
</MudItem>

@code {
    public class CustomCalendarItem : CalendarItem
    {
        public string CssClass { get; set; } = "mud-theme-primary";
    }

    private List<CustomCalendarItem> _events = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        GenerateMockEvents();
    }

    private void GenerateMockEvents()
    {
        var year = DateTime.Today.Year;
        var month = DateTime.Today.Month;
        var daysInMonth = DateTime.DaysInMonth(year, month);

        for (int day = 1; day <= daysInMonth; day++)
        {
            var date = new DateTime(year, month, day);
            var isRestDay = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
            var isHoliday = (month == 6 && day == 12);

            if (isHoliday)
            {
                _events.Add(new CustomCalendarItem
                {
                    Start = date,
                    End = date.AddDays(1),
                    Text = "Independence Day",
                    CssClass = "mud-theme-success"
                });
                continue;
            }

            if (isRestDay)
            {
                _events.Add(new CustomCalendarItem
                {
                    Start = date,
                    End = date.AddDays(1),
                    Text = "Rest Day",
                    CssClass = "mud-theme-secondary"
                });
                continue;
            }

            // Let's randomize a bit for visual appeal. E.g. Late, Overtime, Regular.
            var random = new Random(day);
            var randVal = random.Next(1, 10);
            var shiftText = "Regular Shift";
            var css = "mud-theme-primary";

            if (randVal == 1)
            {
                shiftText = "Absent";
                css = "mud-theme-error";
            }
            if (randVal == 2)
            {
                shiftText = "Late In";
                css = "mud-theme-warning";
            }
            if (randVal == 3)
            {
                shiftText = "Overtime";
                css = "mud-theme-info";
            }

            _events.Add(new CustomCalendarItem
            {
                Start = date.AddHours(8),
                End = date.AddHours(17),
                Text = shiftText,
                CssClass = css
            });
        }
    }
}
