@namespace EduPanel.Components.Pages.Employee.Attendance.Dialogs
@using EduPanel.Components.Pages.Employee.Attendance.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="px-2 pt-2 pb-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">@DialogTitle</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="px-2 pb-2">
            <div class="d-flex flex-column gap-6 mt-2">
                
                <!-- General Information Section -->
                <div>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Transaction No.</MudText>
                            <MudTextField T="string" Value="@Request.TransactionNo" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Date <span class="text-error">*</span>
                            </MudText>
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <MudTextField T="DateTime?" @bind-Value="_fromDate" Format="yyyy-MM-dd" Label="From Date" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                                <MudTextField T="DateTime?" @bind-Value="_toDate" Format="yyyy-MM-dd" Label="To Date" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="d-block mt-2">
                                Note: The Date From should always be on a Monday and Date To on a Sunday
                            </MudText>
                            <MudLink Href="#" Typo="Typo.caption" Color="Color.Primary" Class="d-flex align-center mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" /> Click here to view current day off scheduled
                            </MudLink>
                        </MudItem>
                        
                        <MudDivider />

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Day Off 1 <span class="text-error">*</span>
                            </MudText>
                            <MudSelect T="string" @bind-Value="Request.DayOff1" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("Monday")">Monday</MudSelectItem>
                                <MudSelectItem Value="@("Tuesday")">Tuesday</MudSelectItem>
                                <MudSelectItem Value="@("Wednesday")">Wednesday</MudSelectItem>
                                <MudSelectItem Value="@("Thursday")">Thursday</MudSelectItem>
                                <MudSelectItem Value="@("Friday")">Friday</MudSelectItem>
                                <MudSelectItem Value="@("Saturday")">Saturday</MudSelectItem>
                                <MudSelectItem Value="@("Sunday")">Sunday</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Day Off 2
                            </MudText>
                            <MudSelect T="string" @bind-Value="Request.DayOff2" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("Monday")">Monday</MudSelectItem>
                                <MudSelectItem Value="@("Tuesday")">Tuesday</MudSelectItem>
                                <MudSelectItem Value="@("Wednesday")">Wednesday</MudSelectItem>
                                <MudSelectItem Value="@("Thursday")">Thursday</MudSelectItem>
                                <MudSelectItem Value="@("Friday")">Friday</MudSelectItem>
                                <MudSelectItem Value="@("Saturday")">Saturday</MudSelectItem>
                                <MudSelectItem Value="@("Sunday")">Sunday</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Day Off 3
                            </MudText>
                            <MudSelect T="string" @bind-Value="Request.DayOff3" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("Monday")">Monday</MudSelectItem>
                                <MudSelectItem Value="@("Tuesday")">Tuesday</MudSelectItem>
                                <MudSelectItem Value="@("Wednesday")">Wednesday</MudSelectItem>
                                <MudSelectItem Value="@("Thursday")">Thursday</MudSelectItem>
                                <MudSelectItem Value="@("Friday")">Friday</MudSelectItem>
                                <MudSelectItem Value="@("Saturday")">Saturday</MudSelectItem>
                                <MudSelectItem Value="@("Sunday")">Sunday</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Reason <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="string" @bind-Value="Request.Reason" Required="true" Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </div>
                </div>

            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 pt-2 gap-2 justify-end">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="text-none px-4 font-weight-medium">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" OnClick="Submit" Class="text-none px-6 font-weight-medium">Save changes</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string DialogTitle { get; set; } = "Change Day Off Request";
    [Parameter] public string DialogDescription { get; set; } = "Make changes to your day off schedule here. Click save when you're done.";
    [Parameter] public ChangeDayOffModel Request { get; set; } = new();

    private MudForm _form = default!;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.DateFrom, out var fd)) _fromDate = fd;
        if (DateTime.TryParse(Request.DateTo, out var td)) _toDate = td;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _fromDate == null || _toDate == null)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        Request.DateFrom = _fromDate.Value.ToString("MM/dd/yyyy");
        Request.DateTo = _toDate.Value.ToString("MM/dd/yyyy");

        MudDialog.Close(DialogResult.Ok(Request));
    }
}
