@namespace EduPanel.Components.Pages.Employee.Attendance.Dialogs
@using EduPanel.Components.Pages.Employee.Attendance.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-weight-bold">@DialogTitle</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Style="max-height: 60vh; overflow-y: auto; overflow-x: hidden; padding-right: 8px;">
            <MudGrid Spacing="2">
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Transaction No. :</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField T="string" Value="@Request.TransactionNo" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">
                        Date : <span class="text-error">*</span>
                    </MudText>
                </MudItem>
                <MudItem xs="8">
                    <div class="d-flex gap-2">
                        <MudDatePicker @bind-Date="_fromDate" Placeholder="From" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudDatePicker @bind-Date="_toDate" Placeholder="To" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </div>
                </MudItem>

                <MudItem xs="4"></MudItem>
                <MudItem xs="8">
                    <MudLink Href="#" Typo="Typo.caption" Color="Color.Primary" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                        Click here to view current shift scheduled
                    </MudLink>
                </MudItem>

                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">
                        Shift : <span class="text-error">*</span>
                    </MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudSelect T="string" @bind-Value="Request.GlobalShift" Required="true" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01: 06AM-03PM")">SH-01: 06AM-03PM</MudSelectItem>
                        <MudSelectItem Value="@("SH-02: 08AM-05PM")">SH-02: 08AM-05PM</MudSelectItem>
                        <MudSelectItem Value="@("SH-03: 10AM-07PM")">SH-03: 10AM-07PM</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Monday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Mon :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftMon" Disabled="@(!_enMon)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enMon" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Tuesday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Tue :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftTue" Disabled="@(!_enTue)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enTue" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Wednesday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Wed :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftWed" Disabled="@(!_enWed)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enWed" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Thursday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Thu :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftThu" Disabled="@(!_enThu)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enThu" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Friday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Fri :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftFri" Disabled="@(!_enFri)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enFri" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Saturday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Sat :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftSat" Disabled="@(!_enSat)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enSat" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Sunday -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Shift Sun :</MudText>
                </MudItem>
                <MudItem xs="8" Class="d-flex align-center gap-2">
                    <MudSelect T="string" @bind-Value="Request.ShiftSun" Disabled="@(!_enSun)" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("SH-01")">SH-01</MudSelectItem>
                        <MudSelectItem Value="@("SH-02")">SH-02</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox @bind-Value="_enSun" Label="click to enable." Size="Size.Small" Color="Color.Primary" Class="text-nowrap" />
                </MudItem>

                <!-- Charge To -->
                <MudItem xs="4" Class="d-flex align-center justify-end">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">Charge To :</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudSelect T="string" @bind-Value="Request.ChargeTo" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                        <MudSelectItem Value="@("Company")">Company</MudSelectItem>
                        <MudSelectItem Value="@("Client")">Client</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Reason -->
                <MudItem xs="4" Class="d-flex align-start justify-end mt-2">
                    <MudText Typo="Typo.body2" Class="font-weight-medium">
                        Reason : <span class="text-error">*</span>
                    </MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField T="string" @bind-Value="Request.Reason" Required="true" Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save changes</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string DialogTitle { get; set; } = "Change Shift Request";
    [Parameter] public string DialogDescription { get; set; } = "Make changes to your shift request here. Click save when you're done.";
    [Parameter] public ShiftRequestModel Request { get; set; } = new();

    private MudForm _form = default!;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    
    // Checkbox states for individual days
    private bool _enMon, _enTue, _enWed, _enThu, _enFri, _enSat, _enSun;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.CoveredDateFrom, out var fd)) _fromDate = fd;
        if (DateTime.TryParse(Request.CoveredDateTo, out var td)) _toDate = td;
        
        _enMon = Request.ShiftMon != "-- Select --";
        _enTue = Request.ShiftTue != "-- Select --";
        _enWed = Request.ShiftWed != "-- Select --";
        _enThu = Request.ShiftThu != "-- Select --";
        _enFri = Request.ShiftFri != "-- Select --";
        _enSat = Request.ShiftSat != "-- Select --";
        _enSun = Request.ShiftSun != "-- Select --";
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _fromDate == null || _toDate == null)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        Request.CoveredDateFrom = _fromDate.Value.ToString("MM/dd/yyyy");
        Request.CoveredDateTo = _toDate.Value.ToString("MM/dd/yyyy");

        MudDialog.Close(DialogResult.Ok(Request));
    }
}
