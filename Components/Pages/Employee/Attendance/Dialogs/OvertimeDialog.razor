@namespace EduPanel.Components.Pages.Employee.Attendance.Dialogs
@using EduPanel.Components.Pages.Employee.Attendance.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="px-2 pt-2 pb-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">@DialogTitle</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="px-2 pb-2">
            <div class="d-flex flex-column gap-6 mt-2">
                
                <!-- General Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Overtime Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Transaction No.</MudText>
                            <MudTextField T="string" Value="@("Autonumber")" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Date <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="DateTime?" @bind-Value="_otDate" Format="yyyy-MM-dd" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Time <span class="text-error">*</span>
                            </MudText>
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <MudTextField T="TimeSpan?" @bind-Value="_otIn" Label="OT In" InputType="InputType.Time" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                                <MudTextField T="TimeSpan?" @bind-Value="_otOut" Label="OT Out" InputType="InputType.Time" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                            </div>
                        </MudItem>
                        
                        <MudItem xs="12">
                            <MudCheckBox @bind-Value="Request.ForCto" Label="For Compensatory Time Off" Color="Color.Primary" />
                        </MudItem>
                    </div>
                </div>

                <MudDivider />

                <!-- Additional Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Additional Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Reason <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="string" @bind-Value="Request.Reason" Required="true" Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </div>
                </div>

            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 pt-2 gap-2 justify-end">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="text-none px-4 font-weight-medium">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" OnClick="Submit" Class="text-none px-6 font-weight-medium">Save</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public string DialogTitle { get; set; } = "Overtime Request";
    [Parameter] public string DialogDescription { get; set; } = "File your overtime request here.";
    [Parameter] public OvertimeModel Request { get; set; } = new();

    private MudForm _form = default!;
    private DateTime? _otDate;
    private TimeSpan? _otIn;
    private TimeSpan? _otOut;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.Date, out var dt)) _otDate = dt;
        if (TimeSpan.TryParse(Request.In, out var ti)) _otIn = ti;
        if (TimeSpan.TryParse(Request.Out, out var to)) _otOut = to;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _otDate == null || _otIn == null || _otOut == null)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        Request.Date = _otDate.Value.ToString("yyyy-MM-dd");
        Request.In = _otIn.Value.ToString(@"hh\:mm");
        Request.Out = _otOut.Value.ToString(@"hh\:mm");

        // Calculate basic filed hours dynamically for display (just simple math)
        var duration = _otOut.Value - _otIn.Value;
        if (duration.TotalHours < 0) duration = duration.Add(TimeSpan.FromHours(24)); // cross-midnight case
        Request.FiledHrs = Math.Round(duration.TotalHours, 2).ToString("0.00");

        MudDialog.Close(DialogResult.Ok(Request));
    }
}
