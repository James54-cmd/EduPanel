@namespace EduPanel.Components.Pages.Employee.Attendance.Dialogs
@using EduPanel.Components.Pages.Employee.Attendance.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="px-2 pt-2 pb-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">@DialogTitle</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="px-2 pb-2">
            <div class="d-flex flex-column gap-6 mt-2">
                
                <!-- General Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Leave Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Transaction No.</MudText>
                            <MudTextField T="string" Value="@("Autonumber")" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Leave Type <span class="text-error">*</span>
                            </MudText>
                            <MudSelect T="string" @bind-Value="Request.LeaveType" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                                <MudSelectItem Value="@("Vacation Leave")">Vacation Leave</MudSelectItem>
                                <MudSelectItem Value="@("Sick Leave")">Sick Leave</MudSelectItem>
                                <MudSelectItem Value="@("Official Business (OB)")">Official Business (OB)</MudSelectItem>
                                <MudSelectItem Value="@("Emergency Leave")">Emergency Leave</MudSelectItem>
                            </MudSelect>
                            <MudLink Href="#" Typo="Typo.caption" Color="Color.Primary" Class="d-flex align-center mt-2">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" Color="Color.Info" />
                                Click here to view leave balance
                            </MudLink>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Date <span class="text-error">*</span>
                            </MudText>
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <MudTextField T="DateTime?" @bind-Value="_fromDate" Format="yyyy-MM-dd" Label="From" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                                <MudTextField T="DateTime?" @bind-Value="_toDate" Format="yyyy-MM-dd" Label="To" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                            </div>
                        </MudItem>
                    </div>
                </div>

                <MudDivider />

                <!-- Duration Details Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Duration Details</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Filed Hrs <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="string" @bind-Value="Request.FiledHrs" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudRadioGroup @bind-Value="Request.LeaveDayType" Required="true" Class="d-flex flex-wrap gap-4">
                                <MudRadio Value="@("Whole Day")" Color="Color.Primary" Size="Size.Small">Whole Day</MudRadio>
                                <MudRadio Value="@("1st half")" Color="Color.Primary" Size="Size.Small">1st half</MudRadio>
                                <MudRadio Value="@("2nd half")" Color="Color.Primary" Size="Size.Small">2nd half</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                    </div>
                </div>

                <MudDivider />

                <!-- Additional Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Additional Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Reason <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="string" @bind-Value="Request.Reason" Required="true" Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </div>
                </div>

            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 pt-2 gap-2 justify-end">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="text-none px-4 font-weight-medium">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" OnClick="Submit" Class="text-none px-6 font-weight-medium">Save</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public string DialogTitle { get; set; } = "Leave / OB Request";
    [Parameter] public string DialogDescription { get; set; } = "File your leave or official business request here.";
    [Parameter] public LeaveOBModel Request { get; set; } = new();

    private MudForm _form = default!;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.CoveredDateFrom, out var fd)) _fromDate = fd;
        if (DateTime.TryParse(Request.CoveredDateTo, out var td)) _toDate = td;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _fromDate == null || _toDate == null)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        Request.CoveredDateFrom = _fromDate.Value.ToString("yyyy-MM-dd");
        Request.CoveredDateTo = _toDate.Value.ToString("yyyy-MM-dd");

        MudDialog.Close(DialogResult.Ok(Request));
    }
}
