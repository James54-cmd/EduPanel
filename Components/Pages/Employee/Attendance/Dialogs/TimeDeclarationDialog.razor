@namespace EduPanel.Components.Pages.Employee.Attendance.Dialogs
@using EduPanel.Components.Pages.Employee.Attendance.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="px-2 pt-2 pb-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">@DialogTitle</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="px-2 pb-2">
            <div class="d-flex flex-column gap-6 mt-2">
                
                <!-- General Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">General Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Transaction No.</MudText>
                            <MudTextField T="string" Value="@("Autonumber")" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Date <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="DateTime?" @bind-Value="_date" Format="yyyy-MM-dd" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudLink Href="#" Typo="Typo.caption" Color="Color.Primary" Class="d-flex align-center mt-2">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" Color="Color.Info" />
                                Click here to view raw logs
                            </MudLink>
                        </MudItem>
                    </div>
                </div>

                <MudDivider />

                <!-- Time Details Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Time Details</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">In 1</MudText>
                                    <MudTextField T="TimeSpan?" @bind-Value="_in1" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </div>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Out 1</MudText>
                                    <MudTextField T="TimeSpan?" @bind-Value="_out1" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </div>
                            </div>
                        </MudItem>

                        <MudItem xs="12">
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">In 2</MudText>
                                    <MudTextField T="TimeSpan?" @bind-Value="_in2" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </div>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Out 2</MudText>
                                    <MudTextField T="TimeSpan?" @bind-Value="_out2" InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </div>
                            </div>
                        </MudItem>
                    </div>
                </div>

                <MudDivider />

                <!-- Additional Information Section -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">Additional Information</MudText>
                    <div class="d-flex flex-column gap-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Charge To</MudText>
                            <MudSelect T="string" @bind-Value="Request.ChargeTo" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                                <MudSelectItem Value="@("Company A")">Company A</MudSelectItem>
                                <MudSelectItem Value="@("Company B")">Company B</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Time Declaration Type <span class="text-error">*</span>
                            </MudText>
                            <MudSelect T="string" @bind-Value="Request.DeclarationType" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                                <MudSelectItem Value="@("Missing Time In")">Missing Time In</MudSelectItem>
                                <MudSelectItem Value="@("Missing Time Out")">Missing Time Out</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">
                                Reason <span class="text-error">*</span>
                            </MudText>
                            <MudTextField T="string" @bind-Value="Request.Reason" Required="true" Lines="5" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </div>
                </div>

            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 pt-2 gap-2 justify-end">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="text-none px-4 font-weight-medium">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" OnClick="Submit" Class="text-none px-6 font-weight-medium">Save changes</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public string DialogTitle { get; set; } = "Time Declaration Request";
    [Parameter] public string DialogDescription { get; set; } = "Make changes to your time logs here. Click save when you're done.";
    [Parameter] public TimeDeclarationModel Request { get; set; } = new();

    private MudForm _form = default!;
    private DateTime? _date;
    private TimeSpan? _in1;
    private TimeSpan? _out1;
    private TimeSpan? _in2;
    private TimeSpan? _out2;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.Date, out var fd)) _date = fd;
        if (TimeSpan.TryParse(Request.In1, out var t1)) _in1 = t1;
        if (TimeSpan.TryParse(Request.Out1, out var t2)) _out1 = t2;
        if (TimeSpan.TryParse(Request.In2, out var t3)) _in2 = t3;
        if (TimeSpan.TryParse(Request.Out2, out var t4)) _out2 = t4;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid || _date == null)
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        Request.Date = _date.Value.ToString("yyyy-MM-dd");
        Request.In1 = _in1?.ToString(@"hh\:mm") ?? "";
        Request.Out1 = _out1?.ToString(@"hh\:mm") ?? "";
        Request.In2 = _in2?.ToString(@"hh\:mm") ?? "";
        Request.Out2 = _out2?.ToString(@"hh\:mm") ?? "";

        MudDialog.Close(DialogResult.Ok(Request));
    }
}
