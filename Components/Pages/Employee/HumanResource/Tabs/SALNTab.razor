@namespace EduPanel.Components.Pages.Employee.HumanResource.Tabs
@using EduPanel.Components.Pages.Employee.HumanResource.Models
@using EduPanel.Components.Pages.Employee.HumanResource.Dialogs
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<!-- Top Action Bar -->
<MudItem xs="12" Class="mb-4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 rounded-xl d-flex flex-column flex-md-row align-center justify-end gap-4" Style="position: sticky; top: calc(var(--mud-appbar-height) + 16px); z-index: 100;">
        <div class="d-flex flex-wrap justify-center gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewRequestDialog">Add</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download">Export</MudButton>
        </div>
    </MudPaper>
</MudItem>

<!-- Main Table -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <div class="d-flex flex-column flex-md-row justify-space-between align-md-center align-start w-100 gap-4 mb-4">
            <MudSelect T="string" @bind-Value="_statusFilter" Label="Filter Status" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100%; max-width: 250px;">
                <MudSelectItem Value="@("ALL")">ALL</MudSelectItem>
                <MudSelectItem Value="@("Open")">Open</MudSelectItem>
                <MudSelectItem Value="@("Closed")">Closed</MudSelectItem>
                <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_searchString" Placeholder="Enter text to search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 100%; max-width: 400px;"></MudTextField>
        </div>
        
        <MudTable Items="@_records" Dense="true" Hover="true" Bordered="true" Striped="false"
                  Filter="new Func<SALNModel,bool>(FilterFunc)" MultiSelection="true" @bind-SelectedItems="_selectedRecords"
                  Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden" HorizontalScrollbar="true" Breakpoint="Breakpoint.None">
            <HeaderContent>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Edit</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Trans. No.</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Applicable Year</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Position</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: right;">Income</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Date Filed</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Posted By</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Date Posted</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Print</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Edit" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => EditRequest(context)" Disabled="@(context.Status != "Open")" />
                </MudTd>
                <MudTd DataLabel="Trans. No." Class="font-weight-medium" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; color: var(--mud-palette-primary);">@context.TransactionNo</MudTd>
                <MudTd DataLabel="Applicable Year" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.ApplicableYear</MudTd>
                <MudTd DataLabel="Position" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.Position</MudTd>
                <MudTd DataLabel="Income" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: right;">@context.Income</MudTd>
                <MudTd DataLabel="Date Filed" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">@context.DateFiled</MudTd>
                <MudTd DataLabel="Posted By" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.PostedBy</MudTd>
                <MudTd DataLabel="Date Posted" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">@context.DatePosted</MudTd>
                <MudTd DataLabel="Print" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small" Color="Color.Default" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                    No data to display
                </MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudItem>

@code {
    private string _searchString = "";
    private string _statusFilter = "Open";
    private HashSet<SALNModel> _selectedRecords = new();

    private List<SALNModel> _records = new()
    {
        new()
        {
            TransactionNo = "SALN-0015",
            ApplicableYear = "2026",
            Position = "Software Engineer",
            Income = "450000.00",
            DateFiled = "06/09/2026",
            Status = "Open"
        }
    };

    private async Task OpenNewRequestDialog()
    {
        var parameters = new DialogParameters<SALNDialog>
        {
            { x => x.DialogTitle, "SALN Declaration" },
            { x => x.DialogDescription, "Fill out your Statement of Assets, Liabilities, and Net Worth." },
            { x => x.Request, new SALNModel { TransactionNo = "Autonumber", ApplicableYear = DateTime.Now.Year.ToString() } }
        };

        var dialog = await DialogService.ShowAsync<SALNDialog>("", parameters, new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseButton = false, BackdropClick = false });
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var req = (SALNModel)result.Data!;
            req.TransactionNo = $"SALN-{new Random().Next(1000, 9999)}";
            if (string.IsNullOrEmpty(req.DateFiled))
            {
                req.DateFiled = DateTime.Now.ToString("MM/dd/yyyy");
            }
            req.Status = "Open";
            _records.Insert(0, req);
            Snackbar.Add("SALN record created successfully.", Severity.Success);
            StateHasChanged();
        }
    }

    private async Task EditRequest(SALNModel req)
    {
        // Clone for edit
        var clonedReq = new SALNModel
        {
            TransactionNo = req.TransactionNo,
            ApplicableYear = req.ApplicableYear,
            Position = req.Position,
            Income = req.Income,
            DateFiled = req.DateFiled,
            PostedBy = req.PostedBy,
            DatePosted = req.DatePosted,
            Status = req.Status,
            FilingType = req.FilingType,
            FamilyName = req.FamilyName,
            FirstName = req.FirstName,
            MiddleName = req.MiddleName,
            Address = req.Address,
            AgencyOffice = req.AgencyOffice,
            OfficeAddress = req.OfficeAddress,
            DateAccomplished = req.DateAccomplished,
            TaxIdNo = req.TaxIdNo,
            CommTaxCertNo = req.CommTaxCertNo,
            IssuedAt = req.IssuedAt,
            IssuedOn = req.IssuedOn,
            MaritalStatus = req.MaritalStatus,
            SpouseFamilyName = req.SpouseFamilyName,
            SpouseFirstName = req.SpouseFirstName,
            SpouseMiddleName = req.SpouseMiddleName,
            SpousePosition = req.SpousePosition
        };

        var parameters = new DialogParameters<SALNDialog>
        {
            { x => x.DialogTitle, "Edit SALN Declaration" },
            { x => x.DialogDescription, "Make changes to your SALN." },
            { x => x.Request, clonedReq }
        };

        var dialog = await DialogService.ShowAsync<SALNDialog>("", parameters, new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseButton = false, BackdropClick = false });
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var updatedReq = (SALNModel)result.Data!;
            var index = _records.FindIndex(r => r.TransactionNo == updatedReq.TransactionNo);
            if (index != -1)
            {
                _records[index] = updatedReq;
                Snackbar.Add("SALN record updated successfully.", Severity.Success);
                StateHasChanged();
            }
        }
    }

    private bool FilterFunc(SALNModel req)
    {
        if (_statusFilter != "ALL" && req.Status != _statusFilter)
            return false;

        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (req.TransactionNo.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (req.ApplicableYear.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }
}
