@namespace EduPanel.Components.Pages.Employee.HumanResource.Tabs
@using EduPanel.Components.Pages.Employee.HumanResource.Models
@inject ISnackbar Snackbar

<!-- Top Action Bar -->
<MudItem xs="12" Class="mb-4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 rounded-xl d-flex flex-column flex-md-row align-center justify-space-between gap-4" Style="position: sticky; top: calc(var(--mud-appbar-height) + 16px); z-index: 100;">
        <div class="d-flex align-center gap-4" Style="width: 100%; max-width: 250px;">
            <MudSelect T="string" @bind-Value="_statusFilter" Variant="Variant.Outlined" Margin="Margin.Dense" Style="background-color: white;">
                <MudSelectItem Value="@("Open")">Open</MudSelectItem>
                <MudSelectItem Value="@("Closed")">Closed</MudSelectItem>
                <MudSelectItem Value="@("All")">All</MudSelectItem>
            </MudSelect>
        </div>
    </MudPaper>
</MudItem>

<!-- Main Table -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <MudTable Items="@_notices" Dense="true" Hover="true" Bordered="true" Striped="false"
                  CustomHeader="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
            <HeaderContent>
                <MudTHeadRow>
                    <MudTh RowSpan="2" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center; border-right: 1px solid var(--mud-palette-table-lines);">Edit</MudTh>
                    <MudTh RowSpan="2" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines);">Report No.</MudTh>
                    <MudTh RowSpan="2" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines);">Date Issued</MudTh>
                    <MudTh ColSpan="2" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Offense</MudTh>
                </MudTHeadRow>
                <MudTHeadRow>
                    <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines); border-top: 1px solid var(--mud-palette-table-lines);">DA Policy Type</MudTh>
                    <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-top: 1px solid var(--mud-palette-table-lines);">DA Policy</MudTh>
                </MudTHeadRow>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Edit" Style="font-size: 0.75rem; text-align: center; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines);">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" />
                </MudTd>
                <MudTd DataLabel="Report No." Class="font-weight-medium" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; color: var(--mud-palette-primary); border-right: 1px solid var(--mud-palette-table-lines);">@context.ReportNo</MudTd>
                <MudTd DataLabel="Date Issued" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines);">@context.DateIssued</MudTd>
                <MudTd DataLabel="DA Policy Type" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; border-right: 1px solid var(--mud-palette-table-lines);">@context.DaPolicyType</MudTd>
                <MudTd DataLabel="DA Policy" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.DaPolicy</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                    No data to display
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudItem>

@code {
    private string _statusFilter = "Open";

    private List<NoticeToExplainModel> _notices = new();
}
