@namespace EduPanel.Components.Pages.Employee.HumanResource.Tabs
@using EduPanel.Components.Pages.Employee.HumanResource.Models
@using EduPanel.Components.Pages.Employee.HumanResource.Dialogs
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<!-- Top Action Bar -->
<MudItem xs="12" Class="mb-4">
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 rounded-xl d-flex flex-column flex-md-row align-center justify-end gap-4" Style="position: sticky; top: calc(var(--mud-appbar-height) + 16px); z-index: 100;">
        <div class="d-flex flex-wrap justify-center gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewRequestDialog">Add</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download">Export</MudButton>
        </div>
    </MudPaper>
</MudItem>

<!-- Main Table -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <div class="d-flex flex-column flex-md-row justify-space-between align-md-center align-start w-100 gap-4 mb-4">
            <MudSelect T="string" @bind-Value="_statusFilter" Label="Filter Status" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100%; max-width: 250px;">
                <MudSelectItem Value="@("ALL")">ALL</MudSelectItem>
                <MudSelectItem Value="@("IN PROCESS")">IN PROCESS</MudSelectItem>
                <MudSelectItem Value="@("POSTED")">POSTED</MudSelectItem>
                <MudSelectItem Value="@("CANCELLED / DISAPPROVED")">CANCELLED / DISAPPROVED</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_searchString" Placeholder="Enter text to search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 100%; max-width: 400px;"></MudTextField>
        </div>
        
        <MudTable Items="@_applications" Dense="true" Hover="true" Bordered="true" Striped="false"
                  Filter="new Func<BenefitApplicationModel,bool>(FilterFunc)" MultiSelection="true" @bind-SelectedItems="_selectedApplications"
                  Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden" HorizontalScrollbar="true" Breakpoint="Breakpoint.None">
            <HeaderContent>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Edit</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Transaction No.</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Date Filed</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">Benefit Type</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: right;">Amount</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Status</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Approved /<br/>Disapproved By</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">Approved /<br/>Disapproved Date</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Edit" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => EditRequest(context)" Disabled="@(context.ApprovalStatus != "IN PROCESS")" />
                </MudTd>
                <MudTd DataLabel="Transaction No." Class="font-weight-medium" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; color: var(--mud-palette-primary);">@context.TransactionNo</MudTd>
                <MudTd DataLabel="Date Filed" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: center;">@context.DateFiled</MudTd>
                <MudTd DataLabel="Benefit Type" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle;">@context.BenefitType</MudTd>
                <MudTd DataLabel="Amount" Style="font-size: 0.75rem; white-space: nowrap; vertical-align: middle; text-align: right;">@context.Amount</MudTd>
                <MudTd DataLabel="Status" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">
                    <MudChip T="string" Color="@GetStatusColor(context.ApprovalStatus)" Size="Size.Small" Variant="Variant.Filled">@context.ApprovalStatus</MudChip>
                </MudTd>
                <MudTd DataLabel="Approved By" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.ApprovedBy</MudTd>
                <MudTd DataLabel="Approved Date" Style="font-size: 0.75rem; text-align: center; vertical-align: middle;">@context.ApprovedDate</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                    No data to display
                </MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudItem>

@code {
    private string _searchString = "";
    private string _statusFilter = "IN PROCESS";
    private HashSet<BenefitApplicationModel> _selectedApplications = new();

    private List<BenefitApplicationModel> _applications = new()
    {
        new()
        {
            TransactionNo = "BAPP-0044",
            DateFiled = "06/09/2026",
            BenefitType = "Rice Subsidy",
            Amount = "1500.00",
            Attachment = "receipt.pdf",
            Remarks = "Monthly claim.",
            ApprovalStatus = "IN PROCESS"
        }
    };

    private async Task OpenNewRequestDialog()
    {
        var parameters = new DialogParameters<BenefitApplicationDialog>
        {
            { x => x.DialogTitle, "Benefit Application" },
            { x => x.DialogDescription, "Fill out the details below to apply for a benefit." },
            { x => x.Request, new BenefitApplicationModel { TransactionNo = "Autonumber" } }
        };

        var dialog = await DialogService.ShowAsync<BenefitApplicationDialog>("", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = false, BackdropClick = false });
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var req = (BenefitApplicationModel)result.Data!;
            req.TransactionNo = $"BAPP-{new Random().Next(1000, 9999)}";
            if (string.IsNullOrEmpty(req.DateFiled))
            {
                req.DateFiled = DateTime.Now.ToString("MM/dd/yyyy");
            }
            req.ApprovalStatus = "IN PROCESS";
            _applications.Insert(0, req);
            Snackbar.Add("Application request created successfully.", Severity.Success);
            StateHasChanged();
        }
    }

    private async Task EditRequest(BenefitApplicationModel req)
    {
        var clonedReq = new BenefitApplicationModel
        {
            TransactionNo = req.TransactionNo,
            DateFiled = req.DateFiled,
            BenefitType = req.BenefitType,
            Amount = req.Amount,
            Attachment = req.Attachment,
            Remarks = req.Remarks,
            ApprovalStatus = req.ApprovalStatus,
            ApprovedBy = req.ApprovedBy,
            ApprovedDate = req.ApprovedDate
        };

        var parameters = new DialogParameters<BenefitApplicationDialog>
        {
            { x => x.DialogTitle, "Edit Benefit Application" },
            { x => x.DialogDescription, "Make changes to your benefit application request." },
            { x => x.Request, clonedReq }
        };

        var dialog = await DialogService.ShowAsync<BenefitApplicationDialog>("", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = false, BackdropClick = false });
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var updatedReq = (BenefitApplicationModel)result.Data!;
            var index = _applications.FindIndex(r => r.TransactionNo == updatedReq.TransactionNo);
            if (index != -1)
            {
                _applications[index] = updatedReq;
                Snackbar.Add("Application request updated successfully.", Severity.Success);
                StateHasChanged();
            }
        }
    }

    private bool FilterFunc(BenefitApplicationModel req)
    {
        if (_statusFilter != "ALL" && req.ApprovalStatus != _statusFilter)
            return false;

        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (req.TransactionNo.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (req.BenefitType.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (req.Remarks.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "POSTED" => Color.Success,
        "IN PROCESS" => Color.Warning,
        "CANCELLED / DISAPPROVED" => Color.Error,
        _ => Color.Default
    };
}
