@namespace EduPanel.Components.Pages.Employee.HumanResource.Tabs
@using EduPanel.Components.Pages.Employee.HumanResource.Models

<!-- Main Table -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <div class="d-flex flex-column flex-md-row w-100 mb-4 gap-4 align-center">
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Enter text to search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 100%; max-width: 400px;"></MudTextField>
        </div>
        
        <MudTable Items="@_applications" Dense="true" Hover="true" Bordered="true" Striped="false"
                  Filter="new Func<MyApplicationModel,bool>(FilterFunc)" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
            <HeaderContent>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; font-weight: 700; border-right: 1px solid var(--mud-palette-table-lines);">Status</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; font-weight: 700; border-right: 1px solid var(--mud-palette-table-lines);">Position Title</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; font-weight: 700; border-right: 1px solid var(--mud-palette-table-lines);">Date Applied</MudTh>
                <MudTh Style="font-size: 0.75rem; white-space: nowrap; font-weight: 700;">Applicant Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Status" Style="font-size: 0.75rem; border-right: 1px solid var(--mud-palette-table-lines);">@context.Status</MudTd>
                <MudTd DataLabel="Position Title" Style="font-size: 0.75rem; border-right: 1px solid var(--mud-palette-table-lines);">@context.PositionTitle</MudTd>
                <MudTd DataLabel="Date Applied" Style="font-size: 0.75rem; border-right: 1px solid var(--mud-palette-table-lines);">@context.DateApplied</MudTd>
                <MudTd DataLabel="Applicant Status" Style="font-size: 0.75rem;">@context.ApplicantStatus</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                    No data to display
                </MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudItem>

@code {
    private string _searchString = "";

    private List<MyApplicationModel> _applications = new()
    {
        new()
        {
            Status = "Active",
            PositionTitle = "Senior Software Engineer",
            DateApplied = "05/12/2026",
            ApplicantStatus = "Under Review"
        },
        new()
        {
            Status = "Closed",
            PositionTitle = "Project Manager",
            DateApplied = "02/10/2026",
            ApplicantStatus = "Rejected"
        }
    };

    private bool FilterFunc(MyApplicationModel req)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (req.PositionTitle.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (req.Status.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (req.ApplicantStatus.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }
}
