@namespace EduPanel.Components.Pages.Employee.HumanResource.Dialogs
@using EduPanel.Components.Pages.Employee.HumanResource.Models
@using MudBlazor.Services
@implements IAsyncDisposable
@implements IBrowserViewportObserver
@inject IBrowserViewportService BrowserViewportService
@inject ISnackbar Snackbar

<style>
    .saln-dialog .mud-dialog-content {
        overflow: hidden !important;
        padding-bottom: 0 !important;
    }
    .saln-dialog .mud-tabs-vertical .mud-tab {
        justify-content: flex-end !important;
        text-align: right !important;
    }
</style>

<MudDialog Class="saln-dialog">
    <TitleContent>
        <div class="px-2 pt-2">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">@DialogTitle</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@DialogDescription</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="pa-2 h-100">
            <MudTabs Outlined="true" Position="@_tabPosition" Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="mt-2 w-100" Style="height: calc(100vh - 180px);" TabPanelsClass="pa-6 w-100 overflow-y-auto">
                <MudTabPanel Text="SALN Summary">
                    <div class="d-flex flex-column gap-6 pb-4">
                        
                        <!-- 1. DECLARANT'S INFORMATION -->
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4 mud-primary-text">1. DECLARANT'S INFORMATION</MudText>
                            <MudGrid>
                                <MudItem xs="12" sm="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Transaction No.</MudText>
                                    <MudTextField T="string" Value="@Request.TransactionNo" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="8">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Type of Filing</MudText>
                                    <MudRadioGroup @bind-Value="Request.FilingType">
                                        <MudRadio Value="@("Jointly Filed")" Color="Color.Primary">Jointly</MudRadio>
                                        <MudRadio Value="@("Separately Filed")" Color="Color.Primary">Separately</MudRadio>
                                        <MudRadio Value="@("Not Applicable")" Color="Color.Primary">N/A</MudRadio>
                                    </MudRadioGroup>
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Family Name <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.FamilyName" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">First Name <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.FirstName" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Middle Name</MudText>
                                    <MudTextField T="string" @bind-Value="Request.MiddleName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Address <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.Address" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>
                        </div>

                        <MudDivider />

                        <!-- 2. EMPLOYMENT DETAILS -->
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4 mud-primary-text">2. EMPLOYMENT DETAILS</MudText>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Applicable Year</MudText>
                                    <MudTextField T="string" @bind-Value="Request.ApplicableYear" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Position <span class="text-error">*</span></MudText>
                                    <MudSelect T="string" @bind-Value="Request.Position" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="@("-- Select --")">-- Select --</MudSelectItem>
                                        <MudSelectItem Value="@("Software Engineer")">Software Engineer</MudSelectItem>
                                        <MudSelectItem Value="@("Manager")">Manager</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Agency / Office</MudText>
                                    <MudTextField T="string" @bind-Value="Request.AgencyOffice" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Office Address</MudText>
                                    <MudTextField T="string" @bind-Value="Request.OfficeAddress" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>
                        </div>

                        <MudDivider />

                        <!-- 3. IDENTIFICATION DETAILS -->
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4 mud-primary-text">3. IDENTIFICATION DETAILS</MudText>
                            <MudGrid>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Date Accomplished <span class="text-error">*</span></MudText>
                                    <MudTextField T="DateTime?" @bind-Value="_dateAccomplished" Format="MM/dd/yyyy" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Tax Identification No. <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.TaxIdNo" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Comm. Tax Cert. No. <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.CommTaxCertNo" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Issued At <span class="text-error">*</span></MudText>
                                    <MudTextField T="string" @bind-Value="Request.IssuedAt" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Issued On <span class="text-error">*</span></MudText>
                                    <MudTextField T="DateTime?" @bind-Value="_issuedOn" Format="MM/dd/yyyy" InputType="InputType.Date" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>
                        </div>

                        <MudDivider />

                        <!-- 4. SPOUSE'S INFORMATION -->
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4 mud-primary-text">4. SPOUSE'S INFORMATION</MudText>
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudRadioGroup @bind-Value="Request.MaritalStatus">
                                        <MudRadio Value="@("I am married")" Color="Color.Primary">I am married.</MudRadio>
                                        <MudRadio Value="@("I am not married")" Color="Color.Primary">I am not married.</MudRadio>
                                    </MudRadioGroup>
                                </MudItem>
                                
                                @if (Request.MaritalStatus == "I am married")
                                {
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Family Name</MudText>
                                        <MudTextField T="string" @bind-Value="Request.SpouseFamilyName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">First Name</MudText>
                                        <MudTextField T="string" @bind-Value="Request.SpouseFirstName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Middle Name</MudText>
                                        <MudTextField T="string" @bind-Value="Request.SpouseMiddleName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-medium">Position</MudText>
                                        <MudTextField T="string" @bind-Value="Request.SpousePosition" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </div>

                    </div>
                </MudTabPanel>

                <!-- Placeholders for other tabs to complete the SALN form -->
                <MudTabPanel Text="Unmarried Children Below 18">
                    <MudText Typo="Typo.h6" Class="mb-4">Children Information</MudText>
                </MudTabPanel>
                <MudTabPanel Text="Real Properties">
                    <MudText Typo="Typo.h6" Class="mb-4">Real Properties</MudText>
                </MudTabPanel>
                <MudTabPanel Text="Personal And Other Properties">
                    <MudText Typo="Typo.h6" Class="mb-4">Personal Properties</MudText>
                </MudTabPanel>
                <MudTabPanel Text="Liabilities">
                    <MudText Typo="Typo.h6" Class="mb-4">Liabilities</MudText>
                </MudTabPanel>
                <MudTabPanel Text="Business Interest & Financial Connections">
                    <MudText Typo="Typo.h6" Class="mb-4">Business Interests</MudText>
                </MudTabPanel>
                <MudTabPanel Text="Relatives In Government Service">
                    <MudText Typo="Typo.h6" Class="mb-4">Relatives in Government</MudText>
                </MudTabPanel>
            </MudTabs>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 gap-2 justify-end">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="text-none px-4 font-weight-medium">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" OnClick="Submit" Class="text-none px-6 font-weight-medium">Save</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string DialogTitle { get; set; } = "Statement of Assets, Liabilities, and Net Worth";
    [Parameter] public string DialogDescription { get; set; } = "Fill out your SALN declaration form.";
    [Parameter] public SALNModel Request { get; set; } = new();

    private MudForm? _form;
    private DateTime? _dateAccomplished;
    private DateTime? _issuedOn;

    private Position _tabPosition = Position.Left;

    public Guid Id { get; } = Guid.NewGuid();
    public ResizeOptions ResizeOptions { get; } = new();

    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs browserViewportEventArgs)
    {
        var isMobile = browserViewportEventArgs.Breakpoint <= Breakpoint.Sm;
        var newPos = isMobile ? Position.Top : Position.Left;
        if (_tabPosition != newPos)
        {
            _tabPosition = newPos;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(Request.DateAccomplished, out var da)) _dateAccomplished = da;
        if (DateTime.TryParse(Request.IssuedOn, out var io)) _issuedOn = io;
        
        if (string.IsNullOrEmpty(Request.Position)) Request.Position = "-- Select --";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BrowserViewportService.SubscribeAsync(this, fireImmediately: true);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form!.Validate();
        if (!_form.IsValid || Request.Position == "-- Select --")
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        if (_dateAccomplished.HasValue) Request.DateAccomplished = _dateAccomplished.Value.ToString("MM/dd/yyyy");
        if (_issuedOn.HasValue) Request.IssuedOn = _issuedOn.Value.ToString("MM/dd/yyyy");

        Snackbar.Add("SALN successfully filed.", Severity.Success);
        MudDialog.Close(DialogResult.Ok(Request));
    }

    public async ValueTask DisposeAsync()
    {
        await BrowserViewportService.UnsubscribeAsync(this);
    }
}
