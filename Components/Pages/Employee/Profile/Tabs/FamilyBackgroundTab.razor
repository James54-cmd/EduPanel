@namespace EduPanel.Components.Pages.Employee.ProfileTabs

<div class="d-flex flex-column gap-6">

    <!-- Modern Family Background Table (MudSimpleTable) -->
    <MudPaper Elevation="0" Outlined="true" Class="rounded-lg bg-transparent overflow-hidden">
        <div class="d-flex align-center px-6 py-4 mud-border-bottom">
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Family Background</MudText>
            <MudSpacer />
            <!-- Integrated Search Bar -->
            <MudTextField @bind-Value="searchString" Placeholder="Search family member..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0 mr-4" Style="max-width: 300px;" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
            <!-- Primary Action Button -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="text-transform-none rounded-lg px-4 py-2">Add Family Member</MudButton>
        </div>

        <MudSimpleTable Hover="true" Bordered="true" Elevation="0" Style="overflow-x: auto;">
            <thead>
                <tr>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Record No.</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Name</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Relationship</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Birth Date</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Civil Status</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Contact No.</MudText></th>
                    <th style="width: 120px; text-align: center;"><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Actions</MudText></th>
                </tr>
            </thead>
            <tbody>
                @if (FamilyRecords.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <MudText Typo="Typo.body2" Class="pa-8 mud-text-secondary text-center">No data to display</MudText>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var record in FamilyRecords)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@record.RecordNo</MudText></td>
                            <td class="font-weight-bold" style="color: var(--mud-palette-primary);">@record.Name</td>
                            <td>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined" Class="font-weight-bold">@record.Relationship</MudChip>
                            </td>
                            <td>@record.BirthDate</td>
                            <td class="font-weight-medium">@record.CivilStatus</td>
                            <td>
                                @if (string.IsNullOrEmpty(record.ContactNo))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-style-italic">N/A</MudText>
                                }
                                else
                                {
                                    @record.ContactNo
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-center gap-1">
                                    <MudTooltip Text="Edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                    </MudTooltip>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

</div>

@code {
    private string searchString = "";

    // Added sample data
    private List<FamilyRecordData> FamilyRecords = new()
    {
        new FamilyRecordData { RecordNo = "REC-FAM-001", Name = "Jane Doe", Relationship = "Spouse", BirthDate = "May 14, 2000", CivilStatus = "Married", ContactNo = "0917-123-4567" },
        new FamilyRecordData { RecordNo = "REC-FAM-002", Name = "John Doe Jr.", Relationship = "Child", BirthDate = "Aug 22, 2025", CivilStatus = "Single", ContactNo = "" }
    };

    public class FamilyRecordData
    {
        public string RecordNo { get; set; } = "";
        public string Name { get; set; } = "";
        public string Relationship { get; set; } = "";
        public string BirthDate { get; set; } = "";
        public string CivilStatus { get; set; } = "";
        public string ContactNo { get; set; } = "";
    }
}
