@namespace EduPanel.Components.Pages.Employee.ProfileTabs

<div class="d-flex flex-column gap-6">

    <!-- Modern Employment Record Table (MudSimpleTable) -->
    <MudPaper Elevation="0" Outlined="true" Class="rounded-lg bg-transparent overflow-hidden">
        <div class="d-flex align-center px-6 py-4 mud-border-bottom">
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Employment Record</MudText>
            <MudSpacer />
            <!-- Integrated Search Bar -->
            <MudTextField @bind-Value="searchString" Placeholder="Search records..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0 mr-4" Style="max-width: 300px;" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
            <!-- Primary Action Button -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="text-transform-none rounded-lg px-4 py-2">Add Record</MudButton>
        </div>

        <MudSimpleTable Hover="true" Bordered="true" Elevation="0" Style="overflow-x: auto;">
            <thead>
                <tr>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Transaction No.</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">From</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">To</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Position</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Employer</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Experience</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Monthly Salary</MudText></th>
                    <th style="width: 120px; text-align: center;"><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Actions</MudText></th>
                </tr>
            </thead>
            <tbody>
                @if (EmploymentRecords.Count == 0)
                {
                    <tr>
                        <td colspan="8">
                            <MudText Typo="Typo.body2" Class="pa-8 mud-text-secondary text-center">No data to display</MudText>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var record in EmploymentRecords)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@record.TransactionNo</MudText></td>
                            <td>@record.From</td>
                            <td>@record.To</td>
                            <td class="font-weight-bold" style="color: var(--mud-palette-primary);">@record.Position</td>
                            <td class="font-weight-medium">@record.Employer</td>
                            <td>
                                @if (string.IsNullOrEmpty(record.Experience))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-style-italic">N/A</MudText>
                                }
                                else
                                {
                                    @record.Experience
                                }
                            </td>
                            <td>
                                @if (string.IsNullOrEmpty(record.MonthlySalary))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-style-italic">N/A</MudText>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" Class="font-weight-bold">@record.MonthlySalary</MudChip>
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-center gap-1">
                                    <MudTooltip Text="Edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                    </MudTooltip>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

</div>

@code {
    private string searchString = "";

    // Added sample data
    private List<EmploymentRecordData> EmploymentRecords = new()
    {
        new EmploymentRecordData { TransactionNo = "TRX-EMP-001", From = "Jan 2022", To = "Present", Position = "Software Developer", Employer = "PeopleCore Inc.", Experience = "2 Years", MonthlySalary = "₱ 45,000" },
        new EmploymentRecordData { TransactionNo = "TRX-EMP-002", From = "Jun 2021", To = "Dec 2021", Position = "IT Intern", Employer = "Tech Solutions", Experience = "6 Months", MonthlySalary = "₱ 15,000" }
    };

    public class EmploymentRecordData
    {
        public string TransactionNo { get; set; } = "";
        public string From { get; set; } = "";
        public string To { get; set; } = "";
        public string Position { get; set; } = "";
        public string Employer { get; set; } = "";
        public string Experience { get; set; } = "";
        public string MonthlySalary { get; set; } = "";
    }
}
