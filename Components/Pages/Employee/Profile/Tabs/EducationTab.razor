@namespace EduPanel.Components.Pages.Employee.ProfileTabs

<div class="d-flex flex-column gap-6">

    <!-- Instructive Alert -->
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="rounded-lg mb-2">
        Please include Elementary, Secondary education (if applicable), College/University (if applicable), and Graduate studies (if applicable).
    </MudAlert>

    <!-- Modern Education Table (MudSimpleTable) -->
    <MudPaper Elevation="0" Outlined="true" Class="rounded-lg bg-transparent overflow-hidden">
        <div class="d-flex align-center px-6 py-4 mud-border-bottom">
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Educational Background</MudText>
            <MudSpacer />
            <!-- Integrated Search Bar -->
            <MudTextField @bind-Value="searchString" Placeholder="Search education..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0 mr-4" Style="max-width: 300px;" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
            <!-- Primary Action Button -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="text-transform-none rounded-lg px-4 py-2">Add Education</MudButton>
        </div>

        <MudSimpleTable Hover="true" Bordered="true" Elevation="0" Style="overflow-x: auto;">
            <thead>
                <tr>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Transaction No.</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Level</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">School</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Course</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">From</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">To</MudText></th>
                    <th style="width: 120px; text-align: center;"><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Actions</MudText></th>
                </tr>
            </thead>
            <tbody>
                @if (EducationRecords.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <MudText Typo="Typo.body2" Class="pa-8 mud-text-secondary text-center">No educational background data found.</MudText>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var record in EducationRecords)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@record.TransactionNo</MudText></td>
                            <td><MudChip Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="font-weight-bold">@record.Level</MudChip></td>
                            <td class="font-weight-medium">@record.School</td>
                            <td>
                                @if (string.IsNullOrEmpty(record.Course))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-style-italic">N/A</MudText>
                                }
                                else
                                {
                                    @record.Course
                                }
                            </td>
                            <td>@record.From</td>
                            <td>@record.To</td>
                            <td>
                                <div class="d-flex justify-center gap-1">
                                    <MudTooltip Text="Edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                    </MudTooltip>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

</div>

@code {
    private string searchString = "";

    // Added a couple of sample records to immediately show off the premium design
    private List<EducationRecord> EducationRecords = new()
    {
        new EducationRecord { TransactionNo = "TRX-2021-001", Level = "College", School = "Cebu Institute of Technology - University", Course = "BS Information Technology", From = "2021", To = "2025" },
        new EducationRecord { TransactionNo = "TRX-2015-089", Level = "Secondary", School = "Mandaue City Comprehensive National High School", Course = "", From = "2015", To = "2021" }
    };

    public class EducationRecord
    {
        public string TransactionNo { get; set; } = "";
        public string Level { get; set; } = "";
        public string School { get; set; } = "";
        public string Course { get; set; } = "";
        public string From { get; set; } = "";
        public string To { get; set; } = "";
    }
}
