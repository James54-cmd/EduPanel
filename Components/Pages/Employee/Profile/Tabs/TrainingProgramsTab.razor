@namespace EduPanel.Components.Pages.Employee.ProfileTabs

<div class="d-flex flex-column gap-6">

    <!-- Instructive Alert -->
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="rounded-lg mb-2">
        (Start from the most recent L&D/training program and include only the relevant L&D/training taken for the last five (5) years for Division Chief/Executive/Managerial positions)
    </MudAlert>

    <!-- Modern Training Programs Table (MudSimpleTable) -->
    <MudPaper Elevation="0" Outlined="true" Class="rounded-lg bg-transparent overflow-hidden">
        <div class="d-flex align-center px-6 py-4 mud-border-bottom">
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Training Programs</MudText>
            <MudSpacer />
            <!-- Integrated Search Bar -->
            <MudTextField @bind-Value="searchString" Placeholder="Search training..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0 mr-4" Style="max-width: 300px;" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
            <!-- Primary Action Button -->
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="text-transform-none rounded-lg px-4 py-2">Add Training</MudButton>
        </div>

        <MudSimpleTable Hover="true" Bordered="true" Elevation="0" Style="overflow-x: auto;">
            <thead>
                <tr>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Transaction No.</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Program Title</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Sponsored / Conducted</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">From</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">To</MudText></th>
                    <th><MudText Typo="Typo.subtitle2" Class="font-weight-bold">No. of Hours</MudText></th>
                    <th style="width: 120px; text-align: center;"><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Actions</MudText></th>
                </tr>
            </thead>
            <tbody>
                @if (TrainingRecords.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <MudText Typo="Typo.body2" Class="pa-8 mud-text-secondary text-center">No data to display</MudText>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var record in TrainingRecords)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@record.TransactionNo</MudText></td>
                            <td class="font-weight-medium">@record.ProgramTitle</td>
                            <td>@record.SponsoredConducted</td>
                            <td>@record.From</td>
                            <td>@record.To</td>
                            <td>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="font-weight-bold">@record.NumberOfHours hrs</MudChip>
                            </td>
                            <td>
                                <div class="d-flex justify-center gap-1">
                                    <MudTooltip Text="Edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                    </MudTooltip>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

</div>

@code {
    private string searchString = "";

    // Added sample data
    private List<TrainingRecordData> TrainingRecords = new()
    {
        new TrainingRecordData { TransactionNo = "TRX-TRN-104", ProgramTitle = "Advanced C# and .NET 9", SponsoredConducted = "Microsoft", From = "Mar 10, 2026", To = "Mar 14, 2026", NumberOfHours = "40" },
        new TrainingRecordData { TransactionNo = "TRX-TRN-089", ProgramTitle = "Leadership Training", SponsoredConducted = "Internal HR", From = "Nov 05, 2025", To = "Nov 06, 2025", NumberOfHours = "16" }
    };

    public class TrainingRecordData
    {
        public string TransactionNo { get; set; } = "";
        public string ProgramTitle { get; set; } = "";
        public string SponsoredConducted { get; set; } = "";
        public string From { get; set; } = "";
        public string To { get; set; } = "";
        public string NumberOfHours { get; set; } = "";
    }
}
