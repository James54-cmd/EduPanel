@page "/employee/profile"
@namespace EduPanel.Components.Pages.Employee

<MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Employee Profile</MudText>

<MudPaper Elevation="0" Class="pa-6 rounded-lg">
    <div class="d-flex align-center gap-4 mb-6">
        <MudAvatar Size="Size.Large" Class="avatar-gradient-primary" Style="width: 80px; height: 80px; font-size: 2rem;">E</MudAvatar>
        <div>
            <MudText Typo="Typo.h5" Class="font-weight-bold">Employee Name</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">employee@example.com</MudText>
        </div>
    </div>
    <MudDivider Class="my-4" />
    <MudText Typo="Typo.body1">Role: <strong class="ml-2">Staff Member</strong></MudText>
    <MudText Typo="Typo.body1">Department: <strong class="ml-2">General Operations</strong></MudText>
</MudPaper>
