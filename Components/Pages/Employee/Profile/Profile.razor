@page "/employee/profile"
@namespace EduPanel.Components.Pages.Employee
@using EduPanel.Components.Pages.Employee.ProfileTabs

<div class="pa-4">
    <MudGrid Spacing="4">
        <!-- Sidebar: Avatar and Vertical Tabs -->
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-6 mb-4 rounded-xl mud-width-full d-flex flex-column align-center text-center">
                <MudAvatar Size="Size.Large" Class="avatar-gradient-primary mb-4 elevation-4" Style="width: 120px; height: 120px; font-size: 3rem;">E</MudAvatar>
                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-weight-bold mb-1" Style="letter-spacing: -0.5px;">James Fanuel N. Damaso</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-1 text-uppercase font-weight-bold" Style="letter-spacing: 1px; font-size: 0.75rem;">Date of Birth</MudText>
                <MudText Typo="Typo.body1" Align="Align.Center" Class="font-weight-medium">May 3, 2003</MudText>
            </MudPaper>

            <MudPaper Elevation="2" Class="rounded-xl py-4">
                <div class="d-flex flex-column gap-1">
                    @foreach (var tab in TabNames)
                    {
                        var idx = tab.Key;
                        var name = tab.Value;
                        var isActive = activeIndex == idx;
                        <div @onclick="() => activeIndex = idx"
                             class="@($"sidebar-ribbon cursor-pointer transition-all {(isActive ? "active text-white font-weight-bold" : "mud-text-secondary font-weight-medium")}")">
                            <MudText Typo="Typo.body2" Class="inherit-font-weight" Style="letter-spacing: 0.2px;">@name</MudText>
                        </div>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <!-- Main Content Area -->
        <MudItem xs="12" md="9">
            <MudPaper Elevation="2" Class="pa-8 rounded-xl mud-width-full h-100">
                @if (activeIndex == 0)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Personal Profile</MudText>
                    </div>
                    <PersonalProfileTab />
                }
                else if (activeIndex == 1)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Work Information</MudText>
                    </div>
                    <WorkInformationTab />
                }
                else if (activeIndex == 2)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Education</MudText>
                    </div>
                    <EducationTab />
                }
                else if (activeIndex == 3)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Eligibility</MudText>
                    </div>
                    <EligibilityTab />
                }
                else if (activeIndex == 4)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.WorkHistory" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Employment Record</MudText>
                    </div>
                    <EmploymentRecordTab />
                }
                else if (activeIndex == 5)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.ModelTraining" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Training Programs</MudText>
                    </div>
                    <TrainingProgramsTab />
                }
                else if (activeIndex == 6)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Family Background</MudText>
                    </div>
                    <FamilyBackgroundTab />
                }
                else if (activeIndex == 7)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.VolunteerActivism" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Voluntary Works</MudText>
                    </div>
                    <VoluntaryWorksTab />
                }
                else if (activeIndex == 8)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Language</MudText>
                    </div>
                    <LanguageTab />
                }
                else if (activeIndex == 9)
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Style="letter-spacing: -0.5px;">Other Information</MudText>
                    </div>
                    <OtherInformationTab />
                }
                else
                {
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Large" Color="Color.Secondary" Class="mr-3" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold" Color="Color.Secondary" Style="letter-spacing: -0.5px;">@GetTabName(activeIndex)</MudText>
                    </div>
                    <ProfilePlaceholderTab />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private int activeIndex = 0;

    private readonly Dictionary<int, string> TabNames = new()
    {
        { 0, "Personal Profile" },
        { 1, "Work Information" },
        { 2, "Education" },
        { 3, "Eligibility" },
        { 4, "Employment Record" },
        { 5, "Training Programs" },
        { 6, "Family Background" },
        { 7, "Voluntary Works" },
        { 8, "Language" },
        { 9, "Other Information" },
        { 10, "Character Reference" },
        { 11, "Service Record" },
        { 12, "Accountability" }
    };

    private string GetTabName(int index) => TabNames.TryGetValue(index, out var name) ? name : "Unknown";
}


