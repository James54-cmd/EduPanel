@namespace EduPanel.Components.Pages.Employee.Payroll.Tabs

<!-- Filter / Status Bar -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 rounded-xl">
        <div class="d-flex flex-column flex-md-row align-md-center justify-space-between gap-4 w-100">
            <MudSelect T="string" Label="Loan Status" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="width: 100%; max-width: 250px;" @bind-Value="_selectedStatus" AnchorOrigin="Origin.BottomCenter">
                @foreach (var status in _statuses)
                {
                    <MudSelectItem Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" Class="rounded-lg align-self-center align-self-md-auto">
                <MudButton StartIcon="@Icons.Material.Filled.Print">Print</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Download">Export</MudButton>
            </MudButtonGroup>
        </div>
    </MudPaper>
</MudItem>

<!-- Summary Stat Cards -->
<MudItem xs="12">
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center" Style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); min-height: 90px;">
                <MudText Typo="Typo.caption" Class="font-weight-bold text-uppercase" Style="letter-spacing: 1px; color: #1565c0;">Total Loans</MudText>
                <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #0d47a1;">@_loans.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center" Style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); min-height: 90px;">
                <MudText Typo="Typo.caption" Class="font-weight-bold text-uppercase" Style="letter-spacing: 1px; color: #2e7d32;">Total Granted</MudText>
                <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #1b5e20;">₱ @_loans.Sum(l => l.PrincipalAmount).ToString("N2")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center" Style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); min-height: 90px;">
                <MudText Typo="Typo.caption" Class="font-weight-bold text-uppercase" Style="letter-spacing: 1px; color: #e65100;">Total Paid</MudText>
                <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #bf360c;">₱ @_loans.Sum(l => l.TotalPayment).ToString("N2")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center" Style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%); min-height: 90px;">
                <MudText Typo="Typo.caption" Class="font-weight-bold text-uppercase" Style="letter-spacing: 1px; color: #c62828;">Outstanding Balance</MudText>
                <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #b71c1c;">₱ @_loans.Sum(l => l.Balance).ToString("N2")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudItem>

<!-- Active Loans Table -->
<MudItem xs="12">
    <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
        <div class="d-flex flex-column flex-md-row justify-space-between align-md-center align-start w-100 gap-4 mb-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Loan Records</MudText>
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled" Class="ml-4">@_loans.Count loans</MudChip>
            </div>
            <MudTextField @bind-Value="_searchLoan" Placeholder="Search loans..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 100%; max-width: 300px;"></MudTextField>
        </div>
        <MudTable T="LoanRecord" Items="@_loans" Dense="true" Hover="true" Bordered="true" Striped="false" 
                  Filter="new Func<LoanRecord,bool>(FilterLoanRecord)" @bind-SelectedItem="_selectedLoan"
                  Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden mb-4">
            <HeaderContent>
                <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Loan No.</MudTh>
                <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Loan Type</MudTh>
                <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Granted Date</MudTh>
                <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Start of Deduction</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Principal Amount</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Beginning Balance</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">Interest</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Total Amount</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">No. Of Payments</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Amortization</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Total Payment</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Balance</MudTh>
                <MudTh Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Loan No." Class="font-weight-medium" Style="font-size: 0.8125rem; vertical-align: middle; color: var(--mud-palette-primary);">@context.LoanNo</MudTd>
                <MudTd DataLabel="Loan Type" Style="font-size: 0.8125rem; vertical-align: middle;">@context.LoanType</MudTd>
                <MudTd DataLabel="Granted Date" Style="font-size: 0.8125rem; vertical-align: middle;">@context.GrantedDate</MudTd>
                <MudTd DataLabel="Start of Deduction" Style="font-size: 0.8125rem; vertical-align: middle;">@context.StartDeduction</MudTd>
                <MudTd DataLabel="Principal Amount" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.PrincipalAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="Beginning Balance" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.BeginningBalance.ToString("N2")</MudTd>
                <MudTd DataLabel="Interest" Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">@context.InterestRate</MudTd>
                <MudTd DataLabel="Total Amount" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.TotalAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="No. Of Payments" Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">@context.PaymentsMade / @context.TotalPayments</MudTd>
                <MudTd DataLabel="Amortization" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.Amortization.ToString("N2")</MudTd>
                <MudTd DataLabel="Total Payment" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.TotalPayment.ToString("N2")</MudTd>
                <MudTd DataLabel="Balance" Class="font-weight-bold" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.Balance.ToString("N2")</MudTd>
                <MudTd DataLabel="Status" Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled" Class="px-2">@context.Status</MudChip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                    No loan records found
                </MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudItem>

<!-- Loan Details (shown when a loan is selected) -->
@if (_selectedLoan != null)
{
    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
            <div class="d-flex align-center gap-2 mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Loan Information</MudText>
            </div>

            <MudSimpleTable Bordered="true" Hover="true" Dense="true" Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden" Style="table-layout: fixed;">
                <colgroup>
                    <col style="width: 45%;" />
                    <col style="width: 55%;" />
                </colgroup>
                <tbody>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Loan No.</td>
                        <td class="font-weight-bold" style="font-size: 0.8125rem; vertical-align: middle; color: var(--mud-palette-primary);">@_selectedLoan.LoanNo</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Loan Type</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">@_selectedLoan.LoanType</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Granted Date</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">@_selectedLoan.GrantedDate</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Start of Deduction</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">@_selectedLoan.StartDeduction</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Principal Amount</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">₱ @_selectedLoan.PrincipalAmount.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Interest</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">@_selectedLoan.InterestRate</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Total Amount</td>
                        <td class="font-weight-bold" style="font-size: 0.8125rem; vertical-align: middle;">₱ @_selectedLoan.TotalAmount.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Amortization</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">₱ @_selectedLoan.Amortization.ToString("N2") / month</td>
                    </tr>
                    <tr>
                        <td class="font-weight-medium" style="color: var(--mud-palette-text-secondary); font-size: 0.8125rem; vertical-align: middle;">Status</td>
                        <td style="font-size: 0.8125rem; vertical-align: middle;">
                            <MudChip T="string" Color="@GetStatusColor(_selectedLoan.Status)" Size="Size.Small" Variant="Variant.Filled">@_selectedLoan.Status</MudChip>
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            <!-- Payment Progress -->
            <div class="mt-4">
                <div class="d-flex justify-space-between align-center mb-1">
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: var(--mud-palette-text-secondary);">REPAYMENT PROGRESS</MudText>
                    <MudText Typo="Typo.caption" Class="font-weight-bold">@_selectedLoan.PaymentsMade / @_selectedLoan.TotalPayments payments</MudText>
                </div>
                <MudProgressLinear Color="Color.Primary" Rounded="true" Size="Size.Medium"
                                   Value="@GetPaymentProgress()" Class="mb-2" />
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        Paid: ₱ @_selectedLoan.TotalPayment.ToString("N2")
                    </MudText>
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: var(--mud-palette-error);">
                        Remaining: ₱ @_selectedLoan.Balance.ToString("N2")
                    </MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Payment History -->
    <MudItem xs="12" md="8">
        <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-xl">
            <div class="d-flex flex-column flex-md-row justify-space-between align-md-center align-start w-100 gap-4 mb-4">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Payment History</MudText>
                    <MudText Typo="Typo.caption" Class="ml-4" Style="color: var(--mud-palette-text-secondary);">Loan No. @_selectedLoan.LoanNo</MudText>
                </div>
                <MudTextField @bind-Value="_searchPayment" Placeholder="Search payments..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 100%; max-width: 300px;"></MudTextField>
            </div>
            <MudTable Items="@_paymentHistory" Dense="true" Hover="true" Bordered="true" Striped="false"
                      Filter="new Func<PaymentRecord,bool>(FilterPaymentRecord)"
                      Elevation="0" Class="rounded-lg border border-solid mud-border-lines-default overflow-hidden">
                <HeaderContent>
                    <MudTh Style="font-size: 0.8125rem; text-align: center; vertical-align: middle;">#</MudTh>
                    <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Payroll No.</MudTh>
                    <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Payroll Period</MudTh>
                    <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Month</MudTh>
                    <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Year</MudTh>
                    <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Payment</MudTh>
                    <MudTh Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">Balance</MudTh>
                    <MudTh Style="font-size: 0.8125rem; vertical-align: middle;">Remarks</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="#" Style="font-size: 0.8125rem; text-align: center; vertical-align: middle; color: var(--mud-palette-text-secondary);">@context.DetailNo</MudTd>
                    <MudTd DataLabel="Payroll No." Style="font-size: 0.8125rem; vertical-align: middle;">@context.PayrollNo</MudTd>
                    <MudTd DataLabel="Payroll Period" Style="font-size: 0.8125rem; vertical-align: middle;">@context.PayrollPeriod</MudTd>
                    <MudTd DataLabel="Month" Style="font-size: 0.8125rem; vertical-align: middle;">@context.Month</MudTd>
                    <MudTd DataLabel="Year" Style="font-size: 0.8125rem; vertical-align: middle;">@context.Year</MudTd>
                    <MudTd DataLabel="Payment" Class="font-weight-medium" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.Payment.ToString("N2")</MudTd>
                    <MudTd DataLabel="Balance" Style="font-size: 0.8125rem; text-align: right; vertical-align: middle;">@context.RemainingBalance.ToString("N2")</MudTd>
                    <MudTd DataLabel="Remarks" Style="font-size: 0.8125rem; vertical-align: middle;">
                        @if (!string.IsNullOrEmpty(context.Remarks))
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text" Class="px-0">@context.Remarks</MudChip>
                        }
                        else
                        {
                            <span style="color: var(--mud-palette-text-disabled);">—</span>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Style="text-align: center; color: var(--mud-palette-text-secondary); padding: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Small" Color="Color.Default" Class="mr-1" />
                        No payment records found
                    </MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
}

@code {
    // ── State ──
    private string _selectedStatus = "All";
    private string _searchLoan = "";
    private string _searchPayment = "";
    
    private LoanRecord? _selectedLoanValue;
    private LoanRecord? _selectedLoan
    {
        get => _selectedLoanValue;
        set
        {
            if (_selectedLoanValue != value)
            {
                _selectedLoanValue = value;
                if (value != null)
                {
                    LoadPaymentHistory(value.LoanNo);
                }
            }
        }
    }
    
    private List<PaymentRecord> _paymentHistory = new();

    // ── Data Models ──
    private class LoanRecord
    {
        public string LoanNo { get; set; } = "";
        public string LoanType { get; set; } = "";
        public string GrantedDate { get; set; } = "";
        public string StartDeduction { get; set; } = "";
        public decimal PrincipalAmount { get; set; }
        public decimal BeginningBalance { get; set; }
        public string InterestRate { get; set; } = "";
        public decimal TotalAmount { get; set; }
        public int TotalPayments { get; set; }
        public int PaymentsMade { get; set; }
        public decimal Amortization { get; set; }
        public decimal TotalPayment { get; set; }
        public decimal Balance { get; set; }
        public string Status { get; set; } = "";
    }

    private class PaymentRecord
    {
        public int DetailNo { get; set; }
        public string PayrollNo { get; set; } = "";
        public string PayrollPeriod { get; set; } = "";
        public string Month { get; set; } = "";
        public string Year { get; set; } = "";
        public decimal Payment { get; set; }
        public decimal RemainingBalance { get; set; }
        public string Remarks { get; set; } = "";
    }

    // ── Filter Methods ──
    private bool FilterLoanRecord(LoanRecord loan)
    {
        if (string.IsNullOrWhiteSpace(_searchLoan))
            return true;
        if (loan.LoanNo.Contains(_searchLoan, StringComparison.OrdinalIgnoreCase))
            return true;
        if (loan.LoanType.Contains(_searchLoan, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private bool FilterPaymentRecord(PaymentRecord payment)
    {
        if (string.IsNullOrWhiteSpace(_searchPayment))
            return true;
        if (payment.PayrollNo.Contains(_searchPayment, StringComparison.OrdinalIgnoreCase))
            return true;
        if (payment.PayrollPeriod.Contains(_searchPayment, StringComparison.OrdinalIgnoreCase))
            return true;
        if (payment.Month.Contains(_searchPayment, StringComparison.OrdinalIgnoreCase))
            return true;
        if (payment.Year.Contains(_searchPayment, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

