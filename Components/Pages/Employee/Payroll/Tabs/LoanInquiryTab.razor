    // ── Methods ──
    protected override void OnInitialized()
    {
        // Auto-select the first active loan
        _selectedLoan = _loans.FirstOrDefault(l => l.Status == "Active");
    }

    private void LoadPaymentHistory(string loanNo)
    {
        _paymentHistory = loanNo switch
        {
            "SL-2025-0412" => _paymentHistorySL,
            "PF-2024-0831" => _paymentHistoryPF,
            "CL-2023-0220" => _paymentHistoryCL,
            _ => new()
        };
    }

    private double GetPaymentProgress()
    {
        if (_selectedLoan == null || _selectedLoan.TotalPayments == 0) return 0;
        return (double)_selectedLoan.PaymentsMade / _selectedLoan.TotalPayments * 100;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Primary,
        "Fully Paid" => Color.Success,
        "On Hold" => Color.Warning,
        _ => Color.Default
    };
