@page "/employee/dashboard"
@namespace EduPanel.Components.Pages.Employee

<MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Employee Dashboard</MudText>

<MudPaper Elevation="0" Class="pa-6 rounded-lg text-white card-gradient-blue relative overflow-hidden">
    <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">Welcome Back!</MudText>
    <MudText Typo="Typo.body1">This is your employee dashboard where you can overview your tasks and schedules.</MudText>
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="absolute top-4 right-4 text-white" Style="opacity: 0.5; font-size: 3rem;" />
</MudPaper>
