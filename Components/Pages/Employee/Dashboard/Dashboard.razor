@page "/employee/dashboard"
@namespace EduPanel.Components.Pages.Employee
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<div class="saas-dashboard-container">
    <!-- Shared Welcome Overview: announcements (left) + quick actions hub (right) -->
    <WelcomeOverview Name="James"
                     Subtitle="Here is what's happening with your workspace today."
                     Announcements="Announcements"
                     Actions="QuickActions"
                     OnViewAllAnnouncements='() => ShowPrototypeMessage("Opening all announcements")'
                     OnAnnouncementClick='(a) => ShowPrototypeMessage($"Opening: {a.Title}")' />

    <!-- Quick Stats Row (High UX) -->
    <MudGrid Spacing="4" Class="mb-12">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-6 rounded-xl text-white card-gradient-primary relative overflow-hidden h-100 stat-card cursor-pointer" @onclick='() => Nav.NavigateTo("/employee/attendance/leave-balance")'>
                <MudText Typo="Typo.body1" Class="mb-2" Style="opacity: 0.9;">Available Leave Balance</MudText>
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">14 <span style="font-size: 1.2rem; font-weight: normal;">Days</span></MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.8;">2 days expiring this year</MudText>
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Class="absolute top-4 right-4 text-white" Style="opacity: 0.2; font-size: 4rem;" />
                <div class="card-circle circle-1"></div>
                <div class="card-circle circle-2"></div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-6 rounded-xl text-white card-gradient-secondary relative overflow-hidden h-100 stat-card cursor-pointer" @onclick='() => Nav.NavigateTo("/employee/attendance/schedule-calendar")'>
                <MudText Typo="Typo.body1" Class="mb-2" Style="opacity: 0.9;">Next Scheduled Shift</MudText>
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">08:00 <span style="font-size: 1.2rem; font-weight: normal;">AM</span></MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.8;">Tomorrow (08:00 AM - 04:00 PM)</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="absolute top-4 right-4 text-white" Style="opacity: 0.2; font-size: 4rem;" />
                <div class="card-circle circle-1"></div>
                <div class="card-circle circle-2"></div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-6 rounded-xl text-white card-gradient-success relative overflow-hidden h-100 stat-card cursor-pointer" @onclick='() => Nav.NavigateTo("/employee/human-resource/my-applications")'>
                <MudText Typo="Typo.body1" Class="mb-2" Style="opacity: 0.9;">Pending Requests</MudText>
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">2 <span style="font-size: 1.2rem; font-weight: normal;">Items</span></MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.8;">1 Leave, 1 Overtime</MudText>
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Class="absolute top-4 right-4 text-white" Style="opacity: 0.2; font-size: 4rem;" />
                <div class="card-circle circle-1"></div>
                <div class="card-circle circle-2"></div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Charts & Checklist Row -->
    <MudGrid Spacing="6" Class="mb-12">
        <MudItem xs="12" md="7">
            <MudPaper Elevation="0" Class="pa-6 rounded-xl h-100 chart-card" Style="border: 1px solid #f1f5f9; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);">
                <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Weekly Hours Overview</MudText>
                <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@Series" XAxisLabels="@XAxisLabels" Width="100%" Height="300px" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="0" Class="pa-6 rounded-xl h-100 onboarding-card">
                <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Onboarding Tasks</MudText>
                <MudText Typo="Typo.body2" Class="text-muted mb-6">Complete these steps to set up your profile.</MudText>
                
                <div class="d-flex align-center mb-6">
                    <MudProgressLinear Color="Color.Success" Value="@CompletionPercentage" Class="flex-grow-1 mr-4" Rounded="true" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@CompletionPercentage%</MudText>
                </div>

                <div class="checklist d-flex flex-column gap-3">
                    @foreach (var task in Checklist)
                    {
                        <div class="checklist-item d-flex align-center @(task.IsCompleted ? "completed" : "")" @onclick="() => ToggleTask(task)">
                            <div class="check-circle mr-3 d-flex align-center justify-center">
                                @if (task.IsCompleted)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                }
                            </div>
                            <MudText Typo="Typo.body2" Class="task-text font-weight-medium">@task.Title</MudText>
                        </div>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- HRIS Modules Grid -->
    <div class="modules-section mb-12">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">My Modules</MudText>
        <MudGrid Spacing="4">
            @foreach (var module in Modules)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Elevation="0" Class="module-card pa-6 h-100 d-flex flex-column" @onclick="@(() => Nav.NavigateTo(module.Route))">
                        <div class="icon-wrapper mb-4" style="background-color: @module.IconBgColor;">
                            <MudIcon Icon="@module.Icon" Color="@module.IconColor" Size="Size.Medium" />
                        </div>
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">@module.Title</MudText>
                        <MudText Typo="Typo.body2" Class="text-muted mb-6 flex-grow-1">@module.Description</MudText>
                        <div class="d-flex align-center text-primary font-weight-bold mt-auto" style="gap: 4px; transition: transform 0.2s;">
                            <span>Explore Module</span>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </div>

    <!-- Discover Features Carousel -->
    <div class="discover-section pb-12">
        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Discover Your Portal</MudText>
        <MudCarousel Class="mud-width-full rounded-xl" Style="height: 380px; background: #f8fafc; border: 1px solid #e2e8f0; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);" ShowArrows="true" ShowBullets="true" EnableSwipeGesture="true" AutoCycle="true" TData="object">
            @foreach (var feature in Features)
            {
                <MudCarouselItem Transition="Transition.Slide">
                    <div class="d-flex justify-center align-center h-100 pa-4">
                        <MudPaper Elevation="0" Class="feature-card pa-8 d-flex flex-column align-center text-center h-100 justify-center" Style="width: 100%; max-width: 600px; background: transparent;">
                            <div class="feature-icon mb-6 d-flex align-center justify-center" style="width: 80px; height: 80px; border-radius: 24px; background: white; box-shadow: 0 10px 20px rgba(0,0,0,0.05);">
                                <MudIcon Icon="@feature.Icon" Size="Size.Large" Color="Color.Primary" />
                            </div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold mb-4">@feature.Title</MudText>
                            <MudText Typo="Typo.body1" Class="text-muted mb-8">@feature.Description</MudText>
                            <MudButton Href="@feature.Route" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-lg px-8 py-2 text-none font-weight-bold">Learn More</MudButton>
                        </MudPaper>
                    </div>
                </MudCarouselItem>
            }
        </MudCarousel>
    </div>
</div>

@code {
    private void ShowPrototypeMessage(string action)
    {
        Snackbar.Add($"{action} (Prototype Interaction)", MudBlazor.Severity.Info, config =>
        {
            config.Icon = Icons.Material.Filled.Info;
            config.IconColor = Color.Info;
            config.IconSize = Size.Medium;
        });
    }

    public List<ChartSeries<double>> Series = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "Regular Hours", Data = new double[] { 40, 40, 38, 42, 40 } },
        new ChartSeries<double>() { Name = "Overtime",    Data = new double[] { 2, 0, 0, 4, 1 } },
    };
    public string[] XAxisLabels = { "Week 1", "Week 2", "Week 3", "Week 4", "Week 5" };

    public class ModuleInfo
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Route { get; set; } = "";
        public string Icon { get; set; } = "";
        public Color IconColor { get; set; }
        public string IconBgColor { get; set; } = "";
    }

    public List<ModuleInfo> Modules = new()
    {
        new() { Title = "My Profile", Description = "View and update your personal information and documents.", Route = "/employee/profile", Icon = Icons.Material.Filled.Person, IconColor = Color.Primary, IconBgColor = "rgba(27, 79, 138, 0.1)" },
        new() { Title = "Attendance", Description = "Check your schedules, DTR, and shift changes.", Route = "/employee/attendance/inquiry", Icon = Icons.Material.Filled.AccessTime, IconColor = Color.Secondary, IconBgColor = "rgba(46, 125, 158, 0.1)" },
        new() { Title = "Leave & Time Off", Description = "File leave requests, overtimes, and check available balances.", Route = "/employee/attendance/leave-balance", Icon = Icons.Material.Filled.EventAvailable, IconColor = Color.Success, IconBgColor = "rgba(16, 185, 129, 0.1)" },
        new() { Title = "Payroll & Loans", Description = "View your payroll inquiries, loan details, and contributions.", Route = "/employee/payroll/payroll-inquiry", Icon = Icons.Material.Filled.AttachMoney, IconColor = Color.Warning, IconBgColor = "rgba(245, 158, 11, 0.1)" },
        new() { Title = "Benefits & Requests", Description = "Manage benefit applications, enrollments, and employee requests.", Route = "/employee/human-resource/benefit-balance", Icon = Icons.Material.Filled.LocalActivity, IconColor = Color.Info, IconBgColor = "rgba(14, 165, 233, 0.1)" },
        new() { Title = "Evaluations", Description = "View your performance evaluations and career opportunities.", Route = "/employee/human-resource/employee-evaluation", Icon = Icons.Material.Filled.Insights, IconColor = Color.Error, IconBgColor = "rgba(239, 68, 68, 0.1)" },
        new() { Title = "Learning & Dev't.", Description = "Access training matrices, requests, and implementation.", Route = "/employee/learning-development/training-matrix", Icon = Icons.Material.Filled.School, IconColor = Color.Primary, IconBgColor = "rgba(27, 79, 138, 0.1)" },
        new() { Title = "HR Forms", Description = "Submit SALN forms, clearance, and incident reports.", Route = "/employee/human-resource/saln-form", Icon = Icons.Material.Filled.Assignment, IconColor = Color.Secondary, IconBgColor = "rgba(46, 125, 158, 0.1)" }
    };

    public class ChecklistItem
    {
        public string Title { get; set; } = "";
        public bool IsCompleted { get; set; }
    }

    public List<ChecklistItem> Checklist = new()
    {
        new() { Title = "Complete personal profile", IsCompleted = true },
        new() { Title = "Submit tax requirements", IsCompleted = true },
        new() { Title = "Review company handbook", IsCompleted = false },
        new() { Title = "Complete onboarding training", IsCompleted = false },
        new() { Title = "View upcoming schedule", IsCompleted = false }
    };

    public int CompletionPercentage => Checklist.Any() ? (int)Math.Round((double)Checklist.Count(c => c.IsCompleted) / Checklist.Count * 100) : 0;

    private void ToggleTask(ChecklistItem task)
    {
        task.IsCompleted = !task.IsCompleted;
        if(task.IsCompleted)
            Snackbar.Add($"Task '{task.Title}' marked as completed!", MudBlazor.Severity.Success);
    }

    public List<AnnouncementItem> Announcements = new()
    {
        new() { Badge = "Important", Title = "Upcoming Townhall Meeting", Description = "Join us this Friday for the quarterly company updates.", Date = "October 24, 2026" },
        new() { Badge = "New Feature", Title = "Mobile Payslip Access", Description = "You can now download your payslips directly from your mobile device.", Date = "October 18, 2026" },
        new() { Badge = "Reminder", Title = "Annual Health Exam", Description = "Please schedule your annual physical exam by the end of November.", Date = "October 10, 2026" }
    };

    public List<QuickAction> QuickActions => new()
    {
        new() { Title = "Clock In Now", Description = "Start your shift", Icon = Icons.Material.Filled.AccessTime, Color = Color.Primary, OnClick = () => { ShowPrototypeMessage("Clock In Successful!"); return Task.CompletedTask; } },
        new() { Title = "File Leave / OB", Description = "Request time off", Icon = Icons.Material.Filled.EventNote, Color = Color.Secondary, Href = "/employee/attendance/leave-ob" },
        new() { Title = "View Payslip", Description = "Earnings & deductions", Icon = Icons.Material.Filled.Receipt, Color = Color.Success, Href = "/employee/payroll/payroll-inquiry" },
        new() { Title = "My Schedule", Description = "Upcoming shifts", Icon = Icons.Material.Filled.CalendarMonth, Color = Color.Info, Href = "/employee/attendance/schedule-calendar" },
        new() { Title = "Update Profile", Description = "Personal details", Icon = Icons.Material.Filled.Person, Color = Color.Warning, Href = "/employee/personal-data-update" },
        new() { Title = "My Applications", Description = "Track requests", Icon = Icons.Material.Filled.FactCheck, Color = Color.Error, Href = "/employee/human-resource/my-applications" }
    };

    public class FeatureHighlight
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Route { get; set; } = "";
    }

    public List<FeatureHighlight> Features = new()
    {
        new() { Title = "Employee Self-Service", Description = "Take control of your data by updating your own records and details easily.", Icon = Icons.Material.Filled.ManageAccounts, Route = "/employee/personal-data-update" },
        new() { Title = "Instant Leave Requests", Description = "File leaves on the go and track approval statuses in real-time.", Icon = Icons.Material.Filled.FactCheck, Route = "/employee/attendance/leave-ob" },
        new() { Title = "Transparent Payslips", Description = "Access detailed breakdowns of your earnings and deductions anytime.", Icon = Icons.Material.Filled.RequestQuote, Route = "/employee/payroll/payroll-inquiry" },
        new() { Title = "Company Directory", Description = "Find and connect with colleagues across different departments effortlessly.", Icon = Icons.Material.Filled.AccountTree, Route = "#" }
    };
}
