@namespace EduPanel.Components.UI
@typeparam TItem

<div class="dt-wrapper @(Dense ? "dt-dense" : "")">
    @* ── HEADER (tablet 768+ only) ── *@
    <div class="dt-header" style="grid-template-columns: @GridTemplate;">
        @foreach (var col in Columns)
        {
            <div class="dt-header-cell" style="@col.HeaderStyle">@col.Header</div>
        }
    </div>

    @* ── BODY ── *@
    <div class="dt-body" style="height: @BodyHeight; overflow-y: auto;">
        @if (IsLoading)
        {
            @for (int i = 0; i < PageSize; i++)
            {
                <div class="dt-skeleton-row">
                    @* Mobile skeleton card *@
                    <div class="dt-skeleton-mobile">
                        <div class="dt-skeleton-line" style="width:60%;height:14px;margin-bottom:8px;"></div>
                        <div class="dt-skeleton-line" style="width:40%;height:12px;margin-bottom:12px;"></div>
                        <div class="dt-skeleton-line" style="width:80%;height:14px;margin-bottom:6px;"></div>
                        <div class="dt-skeleton-line" style="width:55%;height:12px;"></div>
                    </div>
                    @* Desktop skeleton row *@
                    <div class="dt-skeleton-desktop" style="grid-template-columns: @GridTemplate;">
                        @foreach (var col in Columns)
                        {
                            <div class="dt-skeleton-line" style="width:70%;height:14px;"></div>
                        }
                    </div>
                </div>
            }
        }
        else if (!PagedItems.Any())
        {
            <div class="dt-empty">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="font-size:3rem; color: var(--mud-palette-text-disabled);" />
                <span>@EmptyText</span>
            </div>
        }
        else
        {
            @foreach (var item in PagedItems)
            {
                <div class="dt-row @(OnRowClick.HasDelegate ? "dt-row--clickable" : "")"
                     @onclick="() => HandleRowClick(item)"
                     role="@(OnRowClick.HasDelegate ? "button" : null)"
                     tabindex="@(OnRowClick.HasDelegate ? 0 : -1)"
                     @onkeydown="(e) => HandleRowKeyDown(e, item)">

                    @* ── MOBILE CARD (< 768px) ── *@
                    <div class="dt-card">
                        @if (MobileCardTemplate != null)
                        {
                            @MobileCardTemplate(item)
                        }
                        else
                        {
                            @* Default: show first 2 cols as title/subtitle, rest as label-value pairs *@
                            @for (int ci = 0; ci < Columns.Count; ci++)
                            {
                                var col = Columns[ci];
                                if (!col.HideOnMobile)
                                {
                                    <div class="dt-card-field">
                                        <span class="dt-card-label">@col.Header</span>
                                        <span class="dt-card-value">@col.CellTemplate(item)</span>
                                    </div>
                                }
                            }
                        }
                    </div>

                    @* ── DESKTOP / TABLET ROW (≥ 768px) ── *@
                    <div class="dt-cols" style="grid-template-columns: @GridTemplate;">
                        @foreach (var col in Columns)
                        {
                            <div class="dt-cell" style="@col.CellStyle">
                                @col.CellTemplate(item)
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ── PAGINATION ── *@
    @if (!IsLoading && TotalItems > 0)
    {
        <div class="dt-pagination">
            <span class="dt-page-info">
                Page @CurrentPage of @TotalPages
                &nbsp;·&nbsp;
                @TotalItems items
            </span>
            <div class="dt-page-buttons">
                <button class="dt-page-btn" disabled="@(CurrentPage <= 1)" @onclick="PrevPage">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Style="font-size:1.1rem;" />
                    <span>Prev</span>
                </button>

                @foreach (var p in PageNumbers)
                {
                    <button class="dt-page-btn @(p == CurrentPage ? "dt-page-btn--active" : "")"
                            @onclick="() => GoToPage(p)">
                        @p
                    </button>
                }

                <button class="dt-page-btn" disabled="@(CurrentPage >= TotalPages)" @onclick="NextPage">
                    <span>Next</span>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="font-size:1.1rem;" />
                </button>
            </div>
        </div>
    }
</div>

@code {
    // ── Column Definition ─────────────────────────────────────────────────────
    public class ColumnDef<T>
    {
        public string Header { get; set; } = "";
        public Func<T, RenderFragment> CellTemplate { get; set; } = _ => @<span></span>;
        public string GridWidth { get; set; } = "1fr"; // e.g. "minmax(100px, 1.5fr)"
        public string HeaderStyle { get; set; } = "";
        public string CellStyle { get; set; } = "";
        public bool HideOnMobile { get; set; } = false;
    }

    // ── Parameters ────────────────────────────────────────────────────────────
    [Parameter, EditorRequired]
    public List<ColumnDef<TItem>> Columns { get; set; } = new();

    [Parameter, EditorRequired]
    public List<TItem> Items { get; set; } = new();

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool Dense { get; set; }

    [Parameter]
    public int PageSize { get; set; } = 10;

    [Parameter]
    public string BodyHeight { get; set; } = "calc(100vh - 28rem)";

    [Parameter]
    public string EmptyText { get; set; } = "No data found";

    [Parameter]
    public EventCallback<TItem> OnRowClick { get; set; }

    /// <summary>Override default card layout with a custom mobile template per item.</summary>
    [Parameter]
    public RenderFragment<TItem>? MobileCardTemplate { get; set; }

    // ── Pagination State ─────────────────────────────────────────────────────
    private int CurrentPage = 1;

    private int TotalItems => Items?.Count ?? 0;
    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);

    private IEnumerable<TItem> PagedItems =>
        (Items ?? Enumerable.Empty<TItem>())
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize);

    /// Visible page numbers (max 5, centered around current page)
    private IEnumerable<int> PageNumbers
    {
        get
        {
            const int maxVisible = 5;
            int half = maxVisible / 2;
            int start = Math.Max(1, CurrentPage - half);
            int end = Math.Min(TotalPages, start + maxVisible - 1);
            if (end - start < maxVisible - 1)
                start = Math.Max(1, end - maxVisible + 1);
            return Enumerable.Range(start, end - start + 1);
        }
    }

    // ── Grid Template ────────────────────────────────────────────────────────
    private string GridTemplate =>
        string.Join(" ", Columns.Select(c => c.GridWidth));

    // ── Handlers ─────────────────────────────────────────────────────────────
    private async Task HandleRowClick(TItem item)
    {
        if (OnRowClick.HasDelegate)
            await OnRowClick.InvokeAsync(item);
    }

    private async Task HandleRowKeyDown(KeyboardEventArgs e, TItem item)
    {
        if ((e.Key == "Enter" || e.Key == " ") && OnRowClick.HasDelegate)
            await OnRowClick.InvokeAsync(item);
    }

    private void PrevPage() { if (CurrentPage > 1) CurrentPage--; }
    private void NextPage() { if (CurrentPage < TotalPages) CurrentPage++; }
    private void GoToPage(int p) { CurrentPage = p; }

    protected override void OnParametersSet()
    {
        // Reset to page 1 when items list changes
        if (CurrentPage > TotalPages && TotalPages > 0)
            CurrentPage = 1;
    }
}
